    -- Single: Section:Button({ Name, Callback }) â€” same as AddButton, returns { row, button, dividerSlot }.
    -- Pair: same call then :SubButton({...}) replaces that row with AddMultiButton (left = first, right = second).
    function SectionApi:Button(nameOrOptions, callbackArg)
        local section = self

        if typeof(callbackArg) == "function" then
            return section:AddButton(nameOrOptions, callbackArg)
        end
        if typeof(nameOrOptions) == "string" and callbackArg ~= nil then
            return section:AddButton(nameOrOptions, callbackArg)
        end

        local Opt
        if typeof(nameOrOptions) == "string" then
            Opt = { Name = nameOrOptions }
        else
            Opt = typeof(nameOrOptions) == "table" and nameOrOptions or {}
        end

        local built = section:AddButton(Opt)
        function built:SubButton(subOptions)
            if self._pairBuilt then
                return self._pairResult
            end
            self._pairBuilt = true
            local Sub = typeof(subOptions) == "table" and subOptions or {}
            if self.row and self.row.Parent then
                if self.dividerSlot and self.dividerSlot.Parent then
                    self.dividerSlot:Destroy()
                end
                self.row:Destroy()
                SectionItemCount = SectionItemCount - 1
            end
            self._pairResult = section:AddMultiButton({
                left = Opt,
                right = Sub,
            })
            return self._pairResult
        end

        return built
    end

