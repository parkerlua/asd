    self._ApplyContentSearchFilter = function()
        local QueryText = tostring(self.ContentSearchQuery or ""):lower()
        QueryText = QueryText:gsub("^%s+", ""):gsub("%s+$", "")
        local ActiveTabInfo = TabContentPanels[ActiveTabIndex]
        if not ActiveTabInfo then
            return
        end
        local TargetMounts = {}
        if ActiveTabInfo.SubtabPanes and #ActiveTabInfo.SubtabPanes > 0 then
            local ActiveSubtabIndex = ActiveTabInfo.ActiveSubtab or 1
            local ActivePane = ActiveTabInfo.SubtabPanes[ActiveSubtabIndex]
            if ActivePane then
                Insert(TargetMounts, ActivePane)
            end
        elseif ActiveTabInfo.Panel then
            Insert(TargetMounts, ActiveTabInfo.Panel)
        end
        for _, Mount in ipairs(TargetMounts) do
            local SectionsHost = Mount:FindFirstChild("sections_host")
            if SectionsHost then
                for _, Section in ipairs(SectionsHost:GetChildren()) do
                    if Section:IsA("GuiObject") and Section.Name == "settings_section" then
                        local SectionTitleLabel = Section:FindFirstChild("section_title")
                        local SectionMatches = QueryText == ""
                        if not SectionMatches and SectionTitleLabel and SectionTitleLabel:IsA("TextLabel") then
                            SectionMatches = string.find(tostring(SectionTitleLabel.Text or ""):lower(), QueryText, 1, true) ~= nil
                        end
                        local Outline = Section:FindFirstChild("outline")
                        local Inline = Outline and Outline:FindFirstChild("inline")
                        local ScrollHost = Inline and Inline:FindFirstChild("scrolling")
                        local AnyVisibleRows = false
                        if ScrollHost and ScrollHost:IsA("ScrollingFrame") then
                            for _, Row in ipairs(ScrollHost:GetChildren()) do
                                local IsDividerRow = Row.Name == "toggle_divider_slot"
                                local IsSearchableRow = Row:IsA("GuiObject") and (
                                    Row.Name == "toggle_row" or Row.Name == "slider_row" or Row.Name == "dropdown_row" or
                                    Row.Name == "textbox_row" or Row.Name == "paragraph_row" or
                                    Row.Name == "section_button_row" or Row.Name == "section_multibutton_row"
                                )
                                if IsDividerRow then
                                    Row.Visible = QueryText == ""
                                elseif IsSearchableRow then
                                    local RowMatches = SectionMatches
                                    if not RowMatches and QueryText ~= "" then
                                        for _, Descendant in ipairs(Row:GetDescendants()) do
                                            if Descendant:IsA("TextLabel") or Descendant:IsA("TextButton") then
                                                local DescText = tostring(Descendant.Text or ""):lower()
                                                if DescText ~= "" and string.find(DescText, QueryText, 1, true) then
                                                    RowMatches = true
                                                    break
                                                end
                                            end
                                        end
                                    end
                                    Row.Visible = RowMatches or QueryText == ""
                                    if Row.Visible then
                                        AnyVisibleRows = true
                                    end
                                end
                            end
                        end
                        Section.Visible = AnyVisibleRows or QueryText == "" or SectionMatches
                    end
                end
            end
        end
    end
