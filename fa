function Library:GetConfig()
    local Config = {}
        for k, v in pairs(self.Flags) do
        if typeof(v) == "table" and v.key ~= nil then
            Config[k] = {
                active = v.active,
                mode = v.mode,
                key = tostring(v.key),
            }
        elseif typeof(v) == "table" and v.Transparency ~= nil and v.Color ~= nil then
            Config[k] = {
                Transparency = v.Transparency,
                Color = v.Color:ToHex(),
            }
        else
            Config[k] = v
        end
    end
    return HttpService:JSONEncode(Config)
end

function Library:LoadConfig(config_json)
    local Config = HttpService:JSONDecode(config_json)
    if typeof(Config) ~= "table" then
        return
    end

    local function ApplyValueToSetter(fn, v)
        if typeof(v) == "table" and v.Transparency ~= nil and v.Color ~= nil then
            local col = v.Color
            if typeof(col) == "string" then
                local hex = col:gsub("^#", ""):gsub("%s+", "")
                if string.match(hex, "^%x%x%x%x%x%x$") then
                    col = Color3.fromHex(hex)
                else
                    col = Color3.new(1, 1, 1)
                end
            end
            fn(col, v.Transparency)
        elseif typeof(v) == "table" and v.active ~= nil then
            fn(v)
        else
            fn(v)
        end
    end

    for k, v in pairs(Config) do
        if k ~= "config_name_list" then
                local bucket = self.ConfigFlagHandlers[k]
            if typeof(bucket) == "table" and #bucket > 0 then
                for _, fn in ipairs(bucket) do
                    if typeof(fn) == "function" then
                        self:InvokeHandler(ApplyValueToSetter, fn, v)
                    end
                end
            else
                    local fn = self.ConfigFlags[k]
                if typeof(fn) == "function" then
                    self:InvokeHandler(ApplyValueToSetter, fn, v)
                end
            end
        end
    end
end

function Library:AddPreset(configJson, presetName)
    if typeof(self.OwnerPresets) ~= "table" then
        self.OwnerPresets = {}
    end
    local Json = configJson
    if typeof(Json) == "table" then
        Json = HttpService:JSONEncode(Json)
    end
    if typeof(Json) ~= "string" or Json == "" then
        return nil
    end
    local Label = tostring(presetName or ("Preset " .. tostring(#self.OwnerPresets + 1)))
    Label = Label:gsub("^%s+", ""):gsub("%s+$", "")
    if Label == "" then
        Label = "Preset " .. tostring(#self.OwnerPresets + 1)
    end
    local Entry = {
        Id = HttpService:GenerateGUID(false),
        Name = Label,
        Json = Json,
    }
    Insert(self.OwnerPresets, Entry)
    if self._RefreshOwnerPresetRows then
        self._RefreshOwnerPresetRows()
    end
    return Entry.Id
end

function Library:CaptureDefaultsSnapshot()
    local s = self:GetConfig()
    if typeof(s) == "string" and s ~= "" then
        self._DefaultConfigJson = s
    end
end

function Library:ResetAllValuesToDefaults(stemForDisk)
    local j = self._DefaultConfigJson
    if typeof(j) ~= "string" or j == "" then
        self:CaptureDefaultsSnapshot()
        j = self._DefaultConfigJson
    end
    if typeof(j) ~= "string" or j == "" then
        return
    end
    if typeof(stemForDisk) ~= "string" or stemForDisk == "" then
        stemForDisk = self.ActiveConfigName
    end
    if typeof(stemForDisk) == "string" and stemForDisk ~= "" and typeof(writefile) == "function" then
        local safe = stemForDisk:gsub("[<>:\"/\\|%?%*]", "_")
        if safe ~= "" then
            self:EnsureDataFolders()
            local path = self.Directory .. "/configs/" .. safe .. ".cfg"
            writefile(path, j)
        end
    end
    self:LoadConfig(j)
end

function Library:EnsureDataFolders()
    for _, path in next, self.Folders do
        makefolder(self.Directory .. path)
    end
end

Library:EnsureDataFolders()

function Library:EnsureDefaultConfigFile()
    local stem = "Default"
    local path = self.Directory .. "/configs/" .. stem .. ".cfg"
    if typeof(isfile) == "function" and isfile(path) then
        return
    end
    self:EnsureDataFolders()
    local payload = "{}"
    local data = self:GetConfig()
    if typeof(data) == "string" and data ~= "" then
        payload = data
    end
    writefile(path, payload)
end

