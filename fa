function Library:NextFlag()
    self._FlagSeq = (self._FlagSeq or 0) + 1
    return string.format("flagnumber%s", self._FlagSeq)
end

function Library:RegisterConfigFlagHandler(flag, handler)
    if typeof(flag) ~= "string" or flag == "" or typeof(handler) ~= "function" then
        return
    end
    local bucket = self.ConfigFlagHandlers[flag]
    if not bucket then
        bucket = {}
        self.ConfigFlagHandlers[flag] = bucket
    end
    Insert(bucket, handler)
    self.ConfigFlags[flag] = handler
end

function Library:RegisterThemeUpdater(handler)
    if typeof(handler) ~= "function" then
        return
    end
    Insert(self.ThemeUpdaters, handler)
end

function Library:InvokeHandler(handler, ...)
    if typeof(handler) ~= "function" then
        return
    end
    task.spawn(handler, ...)
end

function Library:ApplyThemeColors()
    for _, handler in ipairs(self.ThemeUpdaters) do
        handler()
    end
end

function Library:SetPaletteColor(swatchKey, color)
    if typeof(swatchKey) ~= "string" or typeof(color) ~= "Color3" then
        return
    end
    if Palette.Swatches[swatchKey] == nil then
        return
    end
    Palette.Swatches[swatchKey] = color
    self:ApplyThemeColors()
end

function Library:BindSwatchProperty(instance, propertyName, swatchKey)
    if not instance or typeof(propertyName) ~= "string" or typeof(swatchKey) ~= "string" then
        return
    end
    if Palette.Swatches[swatchKey] == nil then
        return
    end
    local function Apply()
        if instance and instance.Parent then
            instance[propertyName] = Palette.Swatches[swatchKey]
        end
    end
    Apply()
    self:RegisterThemeUpdater(Apply)
end

function Library:RefreshNotificationsLayout(animated)
    local List = self.ToastQue
    for i = #List, 1, -1 do
        local Item = List[i]
        if not (Item and Item.Frame and Item.Frame.Parent) then
            table.remove(List, i)
        end
    end
    local Y = 60
    for _, Item in ipairs(List) do
        local Target = Dim2(0, 0, 0, Y)
        if animated then
            self:Tween(Item.Frame, { Position = Target }, Enum.EasingStyle.Quad, 0.22)
        else
            Item.Frame.Position = Target
        end
        Y = Y + Item.Frame.AbsoluteSize.Y + 12
    end
end

