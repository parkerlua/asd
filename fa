        if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then
            return
        end
        LibraryRef:TryCloseColorpickerOutside()
    end)

    cfg.set(cfg.color, cfg.alpha)
    LibraryRef:RegisterConfigFlagHandler(cfg.flag, cfg.set)

    return cfg
end

function Library:Dispose()
    if self._CancelFolderConfigRowStrokes then
        self._CancelFolderConfigRowStrokes()
    end
    for _, conn in ipairs(self.SignalHandles) do
        conn:Disconnect()
    end

    self.SignalHandles = {}
    self.ConfigFlagHandlers = {}
    self.ConfigFlags = {}
    self._PointerOverConfigContextMenu = nil

    if self._ScreenGui then
        self._ScreenGui:Destroy()
        self._ScreenGui = nil
    end
    if self._OverlayGui then
        self._OverlayGui:Destroy()
        self._OverlayGui = nil
    end
    self._ScaledUiRoot = nil
    self._PanelUiScale = nil
    self.Items = nil
    self.Other = nil
    self.CurrentOpen = nil
end

