                Parent = btn,
                FillDirection = Enum.FillDirection.Horizontal,
                VerticalAlignment = Enum.VerticalAlignment.Center,
                HorizontalAlignment = Enum.HorizontalAlignment.Left,
                Padding = Dim(0, 6),
                SortOrder = Enum.SortOrder.LayoutOrder,
            })

            local il = self:CreateInstance("ImageLabel", {
                Parent = btn,
                BackgroundTransparency = 1,
                BorderSizePixel = 0,
                Size = Dim2(0, 11, 0, 11),
                Image = IconAsset,
                ImageColor3 = Rgb(99, 99, 115),
                ScaleType = Enum.ScaleType.Fit,
            })

            local tl = self:CreateInstance("TextLabel", {
                Parent = btn,
                BackgroundTransparency = 1,
                Size = Dim2(0, 0, 0, 0),
                AutomaticSize = Enum.AutomaticSize.XY,
                FontFace = Fonts.Inter,
                Text = nm,
                TextColor3 = Rgb(99, 99, 115),
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
                BorderSizePixel = 0,
            })

            Insert(SubtabBtns, btn)
            Insert(SubtabIcons, il)
            Insert(SubtabLabels, tl)
        end

        local function ApplySubtabStyle(i)
            for j = 1, #SubtabBtns do
                local on = j == i
                SubtabLabels[j].TextColor3 = on and Rgb(255, 255, 255) or Rgb(99, 99, 115)
                SubtabIcons[j].ImageColor3 = on and Rgb(255, 255, 255) or Rgb(99, 99, 115)
            end
        end

        local function MoveSliderTo(btn, UseTween)
            task.defer(function()
                task.wait()
                if not PillTrack.Parent or not btn.Parent then
                    return
                end
                local ap = btn.AbsolutePosition
                local as = btn.AbsoluteSize
                local tp = PillTrack.AbsolutePosition
                local relX = ap.X - tp.X
                local TrackH = PillTrack.AbsoluteSize.Y
                if TrackH < 1 then
                    TrackH = 36
                end
                local pos = Dim2(0, relX, 0, 0)
                local sz = Dim2(0, as.X, 0, TrackH)
                if UseTween then
                    TweenService:Create(slider, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                        Position = pos,
                        Size = sz,
                    }):Play()
                else
                    slider.Position = pos
                    slider.Size = sz
                end
            end)
        end

        local SubtabPanes = {}
        local TabPanel = TabContentInfo and TabContentInfo.Panel
        if TabPanel then
            for di = 1, #defs do
                Insert(SubtabPanes, self:CreateInstance("Frame", {
                    Parent = TabPanel,
                    Name = "subtab_pane",
                    BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    Size = Dim2(1, 0, 0, 0),
                    AutomaticSize = Enum.AutomaticSize.Y,
                    Position = Dim2(0, 0, 0, 0),
                    Visible = di == 1,
                    ZIndex = 5,
                }))
            end
            TabContentInfo.SubtabPanes = SubtabPanes
            TabContentInfo.ActiveSubtab = 1
        end

        if TabIndex == ActiveTabIndex and TabContentInfo and TabContentInfo.Panel then
            TabContentInfo.Panel.Visible = true
            if TabContentInfo.SubtabPanes then
                local aj = TabContentInfo.ActiveSubtab or 1
                for sj, pane in ipairs(TabContentInfo.SubtabPanes) do
                    pane.Visible = sj == aj
                end
            end
        end

        local SubtabHandles = {}
        for di = 1, #defs do
            local SubtabHandle = {
                Index = di,
                TabIndex = TabIndex,
            }
            function SubtabHandle:AddSection(SectionSpec)
                local payload = SectionSpec
                if typeof(payload) == "string" then
                    payload = { name = payload }
                end
                payload = payload or {}
                payload.subtab = self.Index
                return PanelAttachSettingsSection(self.TabIndex, payload)
            end

            function SubtabHandle:Section(SectionSpec)
                return self:AddSection(SectionSpec)
            end

            Insert(SubtabHandles, SubtabHandle)
        end

        TabSubtabsStore[TabIndex] = {
            row = SubtabRow,
            slider = slider,
            PillTrack = PillTrack,
            buttons = SubtabBtns,
            handles = SubtabHandles,
        }

        SyncSubtabsVisibility()

        for i, btn in ipairs(SubtabBtns) do
            self:Connection(btn.MouseButton1Click, function()
                if TabContentInfo and TabContentInfo.SubtabPanes then
                    TabContentInfo.ActiveSubtab = i
                    for j, pane in ipairs(TabContentInfo.SubtabPanes) do
                        pane.Visible = j == i
                    end
                end
                ApplySubtabStyle(i)
                MoveSliderTo(btn, true)
                if self._ApplyContentSearchFilter then
                    self._ApplyContentSearchFilter()
                end
            end)
        end

        task.defer(function()
            task.wait()
            if SubtabBtns[1] then
                ApplySubtabStyle(1)
                MoveSliderTo(SubtabBtns[1], false)
            end
            if self._ApplyContentSearchFilter then
                self._ApplyContentSearchFilter()
            end
            ReflowContentBody()
        end)

        return SubtabHandles
    end

    HeaderDivider = self:CreateInstance("Frame", {
        Parent = sidebar,
        Name = "\0",
        BackgroundColor3 = Palette.Swatches.sidebar,
        BorderSizePixel = 0,
        Size = Dim2(1, 0, 0, 1),
        Position = Dim2(0, 0, 0, 0),
        ZIndex = 3,
    })
    self:BindSwatchProperty(HeaderDivider, "BackgroundColor3", "sidebar")

    ResizeMainToFitSidebar()
    ReflowContentBody()
    task.defer(function()
        task.wait()
        if main and main.Parent then
            main.Position = Dim2(0, main.AbsolutePosition.X, 0, main.AbsolutePosition.Y)
        end
    end)

    self:MakeDraggable(main, { ContentFolderBtn, FolderPopup, ContentSettingsBtn, SettingsPopup, WatermarkPopup })

    self:Connection(main.InputBegan, function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then
            return
        end
        self:TryCloseColorpickerOutside()
    end)

    local function AddPage(first, second, third)
        if typeof(first) == "table" and first.Screen ~= nil then
            return AddTabImpl(second, third)
        end
        return AddTabImpl(first, second)
    end

    self:FinalizeWindowSetup()

    return {
        Screen = screen,
        Main = main,
        Body = body,
        Sidebar = sidebar,
        SidebarInner = SidebarInner,
        SidebarHeader = SidebarHeader,
        SidebarTitle = SidebarTitle,
        TitleGradientLine = TitleGradientLine,
        SidebarTabStack = SidebarTabStack,
        TabButtons = TabButtons,
        HeaderDivider = HeaderDivider,
        Content = content,
        ContentTop = content_top,
        ContentSettingsBtn = ContentSettingsBtn,
        ContentSearch = content_search,
        ContentSearchInput = ContentSearchInput,
        ContentFolderBtn = ContentFolderBtn,
        FolderPopup = FolderPopup,
        SettingsPopup = SettingsPopup,
        ContentSubtabsHost = ContentSubtabsHost,
        ContentBody = ContentBody,
        AddTab = AddPage,
        Page = AddPage,
        SetActiveTab = function(first, second)
            local idx
            if typeof(first) == "table" and first.Screen ~= nil then
                idx = second
            elseif typeof(first) == "table" and first.Index ~= nil then
                idx = first.Index
            else
                idx = first
            end
            ApplyTabStyle(idx)
        end,
        SetActivePage = function(first, second)
            local idx
            if typeof(first) == "table" and first.Screen ~= nil then
                idx = second
            elseif typeof(first) == "table" and first.Index ~= nil then
                idx = first.Index
            else
                idx = first
            end
            ApplyTabStyle(idx)
        end,
        AddDivider = function()
            AddDividerImpl()
        end,
        CreateSettingsSection = function(SectionSpec)
            return PanelAttachSettingsSection(ActiveTabIndex, SectionSpec)
        end,
    }
end

function Library:FinalizeWindowSetup()
    self:ApplyThemeColors()
    self:CaptureDefaultsSnapshot()
    self:EnsureDefaultConfigFile()
    if self._RefreshFolderConfigRows then
        self._RefreshFolderConfigRows()
    end
    task.defer(function()
        task.wait()
        self:CaptureDefaultsSnapshot()
    end)
end

--// bootstrap

getgenv().Library = Library

return Library

