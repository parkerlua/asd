    -- MouseButton1Down + defer (same idea as create): InputEnded can close the menu before MouseButton1Click fires,
    -- which would skip the handler; keep the menu up until deferred work finishes.
    self:Connection(BtnContextReset.MouseButton1Down, function()
        local row = ConfigContextTargetRow
        local meta = row and FolderConfigRowMeta[row]
        local stem = meta and meta.stem
        task.defer(function()
            -- Wait one frame so colorpicker / layout AbsoluteSize is valid (cfg.set uses tweens from sizes).
            task.wait()
            Library:ResetAllValuesToDefaults(stem)
        end)
    end)
    local lastFolderConfigUpdateTick = 0
    self:Connection(BtnContextUpdate.MouseButton1Down, function()
        local row = ConfigContextTargetRow
        local meta = row and FolderConfigRowMeta[row]
        local stem = meta and meta.stem
        task.defer(function()
            local now = tick()
            if now - lastFolderConfigUpdateTick < 0.15 then
                return
            end
            lastFolderConfigUpdateTick = now
            if typeof(stem) ~= "string" or stem == "" then
                return
            end
            local safe = stem:gsub("[<>:\"/\\|%?%*]", "_")
            if safe == "" then
                return
            end
            Library:EnsureDataFolders()
            local path = Library.Directory .. "/configs/" .. safe .. ".cfg"
            writefile(path, Library:GetConfig())
            setclipboard("Customer config updated\n" .. path)
        end)
    end)
    self:Connection(BtnContextDelete.MouseButton1Down, function()
        local row = ConfigContextTargetRow
        local meta = row and FolderConfigRowMeta[row]
        local stem = meta and meta.stem
        task.defer(function()
            if typeof(stem) ~= "string" or stem == "" then
                CloseConfigContextMenu()
                return
            end
            local path = Library.Directory .. "/configs/" .. stem .. ".cfg"
            if typeof(delfile) == "function" then
                delfile(path)
            end
            if Library.ActiveConfigName == stem then
                Library.ActiveConfigName = nil
                FolderConfigSelect(nil)
            end
            if Library._RefreshFolderConfigRows then
                Library._RefreshFolderConfigRows()
            end
            CloseConfigContextMenu()
        end)
    end)

    -- InputEnded + defer: avoid closing while the pointer is still over the menu row (one-frame hover gaps).
    self:Connection(UserInputService.InputEnded, function(input, gameProcessed)
        if gameProcessed then
            return
        end
        if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then
            return
        end
        if not ConfigContextWrap.Visible then
            return
        end
        task.defer(function()
            if not ConfigContextWrap.Visible then
                return
            end
            if PointerOverAnyFolderConfigMenu() then
                return
            end
            if self:Hovering(ConfigContextMenu) then
                return
            end
            if
                self:Hovering(BtnContextReset)
                or self:Hovering(BtnContextUpdate)
                or self:Hovering(BtnContextDelete)
            then
                return
            end
            for _, r in ipairs(FolderConfigRows) do
                if self:Hovering(r) then
                    return
                end
                local hit = r:FindFirstChild("config_row_hit")
                if hit and hit:IsA("GuiObject") and self:Hovering(hit) then
                    return
                end
                local menuHit = r:FindFirstChild("config_row_menu")
                if menuHit and menuHit:IsA("GuiObject") and self:Hovering(menuHit) then
                    return
                end
            end
            CloseConfigContextMenu()
        end)
    end)

