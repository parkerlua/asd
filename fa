            if not KeepSettingsPopupOpen and LibraryRef._CloseSettingsPopup then
                LibraryRef._CloseSettingsPopup()
            end
            if LibraryRef._ShowColorpickerDim then
                LibraryRef._ShowColorpickerDim()
            end
        else
            if LibraryRef._IsSettingsPopupVisible and LibraryRef._IsSettingsPopupVisible() then
                if LibraryRef._ShowFolderDimOverlay then
                    LibraryRef._ShowFolderDimOverlay()
                end
            elseif LibraryRef._HideColorpickerDim then
                LibraryRef._HideColorpickerDim()
            end
        end
        items.colorpicker_fade.BackgroundTransparency = 0
        items.colorpicker_holder.Parent = bool and LibraryRef.Items or LibraryRef.Other
        local ap = Trigger.AbsolutePosition
        local as = Trigger.AbsoluteSize
        items.colorpicker_holder.Position = Dim2(0, ap.X + PopupOffsetX, 0, ap.Y + as.Y + PopupOffsetY)
        LibraryRef:Tween(items.colorpicker_fade, { BackgroundTransparency = 1 }, Enum.EasingStyle.Quad, 0.4)
        LibraryRef:Tween(items.colorpicker_holder, {
            Position = items.colorpicker_holder.Position + Dim2(0, 0, 0, 20),
