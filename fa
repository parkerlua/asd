function Library:SetActiveToggleSubOptionsSection(sectionApi)
    if self._ActiveToggleSubOptionsSectionRoot and self._ActiveToggleSubOptionsSectionRoot.Parent then
        self._ActiveToggleSubOptionsSectionRoot.Visible = false
        self._ActiveToggleSubOptionsSectionRoot.Parent = nil
    end
    self._ActiveToggleSubOptionsSectionRoot = nil
    if sectionApi and sectionApi.Root then
        sectionApi.Root.Parent = self._ToggleSubOptionsBody
        sectionApi.Root.LayoutOrder = 1
        sectionApi.Root.Visible = true
        self._ActiveToggleSubOptionsSectionRoot = sectionApi.Root
    end
end

function Library:CreateToggleSubOptionsSection(titleText)
    local body = self._ToggleSubOptionsBody
    if not body then
        return nil
    end
    local sectionApi = self:CreateSettingsSection(body, {
        Name = tostring(titleText or "Sub options"),
        NoDividers = true,
    })
    if sectionApi and sectionApi.Root then
        local sectionTitle = sectionApi.Root:FindFirstChild("section_title")
        if sectionTitle then
            sectionTitle:Destroy()
        end
        local outline = sectionApi.Root:FindFirstChild("outline")
        if outline then
            outline.BackgroundTransparency = 1
            local inline = outline:FindFirstChild("inline")
            if inline then
                inline.BackgroundTransparency = 1
            end
        end
        self._ToggleSubOptionsSectionOrder = (self._ToggleSubOptionsSectionOrder or 0) + 1
        sectionApi.Root.Visible = false
        sectionApi.Root.Parent = nil
    end
    return sectionApi
end

