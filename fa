    end)
    LibraryRef:Connection(items.sat.MouseButton1Down, function()
        cfg._suppress_colorpicker_outside_close = true
        dragging_sat = true
        cfg.update_color()
    end)
    LibraryRef:Connection(items.satvalpicker.MouseButton1Down, function()
        cfg._suppress_colorpicker_outside_close = true
        dragging_sat = true
        cfg.update_color()
    end)

    LibraryRef:Connection(items.input.FocusLost, function()
        local text = items.input.Text
        local parsedColor, parsedT = ParseHex8(text)
        if parsedColor and parsedT ~= nil then
            cfg.set(parsedColor, parsedT)
        else
            local r, g, b, al = LibraryRef:Convert(text)
            if r and g and b and al then
                cfg.set(Rgb(r, g, b), 1 - al)
            else
                items.input.Text = Hex8FromColor(GlyphLabel.ImageColor3, a)
            end
        end
        LibraryRef:Tween(items.input, { TextColor3 = Rgb(255, 255, 255) }, Enum.EasingStyle.Quad, 0.15)
    end)

    LibraryRef:Connection(items.input.Focused, function()
        LibraryRef:Tween(items.input, { TextColor3 = Rgb(255, 255, 255) }, Enum.EasingStyle.Quad, 0.15)
    end)

    LibraryRef:Connection(items.footer_bar.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            cfg._suppress_colorpicker_outside_close = true
