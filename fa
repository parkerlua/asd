    local lastFolderCreateTick = 0
    local function RunFolderConfigCreate()
        local now = tick()
        if now - lastFolderCreateTick < 0.15 then
            return
        end
        lastFolderCreateTick = now
        -- Defer so the popup stays up for this input frame; do not close before save (avoids missed clicks / hover).
        task.defer(function()
            Library:EnsureDataFolders()
            local raw = FolderCreatePresetNameInput.Text or ""
            local name = tostring(raw):gsub("^%s+", ""):gsub("%s+$", "")
            if name == "" then
                setclipboard("Customer config: enter a name before saving.")
                return
            end
            name = name:gsub("[<>:\"/\\|%?%*]", "_")
            if #name > 120 then
                name = name:sub(1, 120)
            end
            local path = Library.Directory .. "/configs/" .. name .. ".cfg"
            writefile(path, Library:GetConfig())
            setclipboard("Customer config saved\n" .. path)
            if Library._RefreshFolderConfigRows then
                Library._RefreshFolderConfigRows()
            end
            FolderCreatePresetNameInput.Text = ""
        end)
    end

