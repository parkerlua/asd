    local function OpenToggleSubOptionsPopup(anchorButton, sectionApi)
        if tick() - (self._LastToggleSubOptionsCloseTick or 0) < 0.12 then
            return
        end
        if Library._DropdownClose then
            Library._DropdownClose()
        end
        if Library._CloseFolderPopup then
            Library._CloseFolderPopup()
        end
        if Library._CloseSettingsPopup then
            Library._CloseSettingsPopup()
        end
        HideColorpickerDim()
        CancelFolderDimTween()
        FolderDim.Visible = false
        FolderDim.BackgroundTransparency = 1

        CancelToggleSubOptionsDimTween()
        ToggleSubOptionsDim.Visible = true
        ToggleSubOptionsDim.BackgroundTransparency = 1
        self._ToggleSubOptionsDimTween = TweenService:Create(ToggleSubOptionsDim, FolderAnimIn,
            { BackgroundTransparency = FolderDimTargetT })
        self._ToggleSubOptionsDimTween:Play()
        self:SetActiveToggleSubOptionsSection(sectionApi)

        local PopupWidth = ToggleSubOptionsPopup.Size.X.Offset
        local TargetHeight = 180
        if sectionApi and sectionApi.Root then
            TargetHeight = math.max(140, sectionApi.Root.AbsoluteSize.Y + 20)
        end
        local MainHeight = main.AbsoluteSize.Y
        local MaxHeight = math.max(140, MainHeight - 20)
        local PopupHeight = math.clamp(TargetHeight, 140, MaxHeight)
        ToggleSubOptionsPopup.Size = Dim2(0, PopupWidth, 0, PopupHeight)

        local PopupW = ToggleSubOptionsPopup.Size.X.Offset
        local PopupH = ToggleSubOptionsPopup.Size.Y.Offset
        local MainAbsPos = main.AbsolutePosition
        local MainAbsSize = main.AbsoluteSize
        local PosX = 20
        local PosY = 70
        if anchorButton and anchorButton.Parent then
            local AnchorAbsPos = anchorButton.AbsolutePosition
            local AnchorAbsSize = anchorButton.AbsoluteSize
            local AnchorX = AnchorAbsPos.X - MainAbsPos.X
            local AnchorY = AnchorAbsPos.Y - MainAbsPos.Y
            local RightX = AnchorX + AnchorAbsSize.X + 8 - 15
            local LeftX = AnchorX - PopupW - 8 - 15
            if RightX + PopupW <= MainAbsSize.X - 10 then
                PosX = RightX
            else
                PosX = LeftX
            end
            PosY = AnchorY + math.floor((AnchorAbsSize.Y - PopupH) * 0.5) + 60
        end
        PosX = math.clamp(PosX, 10, math.max(10, MainAbsSize.X - PopupW - 10))
        PosY = math.clamp(PosY, 10, math.max(10, MainAbsSize.Y - PopupH - 10))
        ToggleSubOptionsPopup.Position = Dim2(0, PosX, 0, PosY)
        ToggleSubOptionsPopup.Visible = true
    end

