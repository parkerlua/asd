    local function ApplyTabStyle(index)
        ActiveTabIndex = index
        for i, row in ipairs(TabButtons) do
            local on = i == index
            row.BackgroundColor3 = Palette.Swatches.tab_active
            row.BackgroundTransparency = on and 0 or 1
            local NameLabel = TabNameLabels[i]
            if NameLabel then
                NameLabel.TextColor3 = on and Rgb(213, 213, 214) or Rgb(78, 78, 91)
            end
            local IconLabel = TabIconLabels[i]
            if IconLabel then
                IconLabel.ImageColor3 = on and Rgb(213, 213, 214) or Rgb(152, 152, 172)
            end
            local TabContentInfo = TabContentPanels[i]
            if TabContentInfo and TabContentInfo.Panel then
                TabContentInfo.Panel.Visible = on
                if on and TabContentInfo.SubtabPanes then
                    local j = TabContentInfo.ActiveSubtab or 1
                    for sj, pane in ipairs(TabContentInfo.SubtabPanes) do
                        pane.Visible = sj == j
                    end
                end
            end
        end
        if SyncSubtabsVisibility then
            SyncSubtabsVisibility()
        end
        if CloseFolderPopup then
            CloseFolderPopup()
        end
        if CloseSettingsPopup then
            CloseSettingsPopup()
        end
        if self._ApplyContentSearchFilter then
            self._ApplyContentSearchFilter()
        end
    end

    local function ResolveTabIcon(icon)
        if icon == nil then
            return DefaultTabIcon
        end
        if typeof(icon) == "number" then
            return "rbxassetid://" .. tostring(icon)
        end
        if typeof(icon) == "string" then
            if icon:find("^rbxassetid://") or icon:find("^rbxthumb://") or icon:find("^http") then
                return icon
            end
            return "rbxassetid://" .. icon
        end
        return DefaultTabIcon
    end

    local function NormalizeSubtabDefs(...)
        local a = { ... }
        if #a == 0 then
            return {}
        end
        if #a == 1 and typeof(a[1]) == "table" then
            local t = a[1]
            if t.name ~= nil or t.title ~= nil then
                return { t }
            end
            return t
        end
        local out = {}
        for _, v in ipairs(a) do
            if typeof(v) == "table" and (v.name ~= nil or v.title ~= nil) then
                Insert(out, v)
            end
        end
        if #out > 0 then
            return out
        end
        for i = 1, #a, 2 do
            Insert(out, { name = a[i], icon = a[i + 1] })
        end
        return out
    end

