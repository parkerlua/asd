function Library:Hovering(UiObject)
    local m = UserInputService:GetMouseLocation()
    local ap = UiObject.AbsolutePosition
    local as = UiObject.AbsoluteSize

    return m.X >= ap.X and m.X <= ap.X + as.X and m.Y >= ap.Y and m.Y <= ap.Y + as.Y
end

function Library:MakeDraggable(frame, excludeFromDrag)
    excludeFromDrag = excludeFromDrag or {}
    local dragging = false
    local AbsStart = nil
    local InputStart = nil
    local ActiveInput = nil

    local function GetScale()
        local p = frame.Parent
        while p do
            local us = p:FindFirstChildOfClass("UIScale")
            if us then return us.Scale end
            p = p.Parent
        end
        return 1
    end

    local function IsPointerOver(UiObject, PointerPosition)
        if not (typeof(UiObject) == "Instance" and UiObject.Parent and PointerPosition) then
            return false
        end
        local ap = UiObject.AbsolutePosition
        local as = UiObject.AbsoluteSize
        return PointerPosition.X >= ap.X and PointerPosition.X <= ap.X + as.X and PointerPosition.Y >= ap.Y and PointerPosition.Y <= ap.Y + as.Y
    end

    self:Connection(frame.InputBegan, function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
        local pos = input.Position
        for _, ex in ipairs(excludeFromDrag) do
            if IsPointerOver(ex, pos) then return end
        end
        dragging = true
        InputStart = pos
        AbsStart = frame.AbsolutePosition
        ActiveInput = input
    end)

    self:Connection(frame.InputEnded, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
            InputStart = nil
            AbsStart = nil
            ActiveInput = nil
        end
    end)

    self:Connection(UserInputService.InputChanged, function(input)
        if not dragging or not InputStart or not AbsStart then return end
        if input.UserInputType == Enum.UserInputType.Touch and input ~= ActiveInput then return end
        if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
        local Scale = GetScale()
        local vx = Camera.ViewportSize.X
        local vy = Camera.ViewportSize.Y
        local fw = frame.AbsoluteSize.X
        local fh = frame.AbsoluteSize.Y
        local ap = frame.AnchorPoint
        local NewAbsX = math.clamp(AbsStart.X + (input.Position.X - InputStart.X), 0, vx - fw)
        local NewAbsY = math.clamp(AbsStart.Y + (input.Position.Y - InputStart.Y), 0, vy - fh)
        self:EaseTo(frame, { Position = Dim2(0, (NewAbsX + ap.X * fw) / Scale, 0, (NewAbsY + ap.Y * fh) / Scale) }, Enum.EasingStyle.Linear, 0.05)
    end)
end

function Library:Tween(obj, properties, easing_style, time)
    TweenService:Create(
        obj,
        TweenInfo.new(time or 0.25, easing_style or Enum.EasingStyle.Quint, Enum.EasingDirection.InOut, 0, false, 0),
        properties
    ):Play()
end

function Library:BindButtonClickAnimation(Button)
    if not (typeof(Button) == "Instance" and Button:IsA("TextButton")) then
        return
    end
    if Button:GetAttribute("ClickAnimationBound") then
        return
    end
    Button:SetAttribute("ClickAnimationBound", true)

    local Pressed = false
    local function PlayPressed()
        self:Tween(Button, { BackgroundColor3 = Rgb(52, 52, 64) }, Enum.EasingStyle.Quad, 0.06)
    end

    local function PlayReleased()
        self:Tween(Button, { BackgroundColor3 = Palette.Swatches.control }, Enum.EasingStyle.Quad, 0.12)
    end

    self:Connection(Button.InputBegan, function(Input)
        if Input.UserInputType ~= Enum.UserInputType.MouseButton1 and Input.UserInputType ~= Enum.UserInputType.Touch then
            return
        end
        Pressed = true
        PlayPressed()
    end)

    self:Connection(Button.InputEnded, function(Input)
        if Input.UserInputType ~= Enum.UserInputType.MouseButton1 and Input.UserInputType ~= Enum.UserInputType.Touch then
            return
        end
        Pressed = false
        PlayReleased()
    end)

    self:Connection(Button.MouseLeave, function()
        if not Pressed then
            return
        end
        Pressed = false
        PlayReleased()
    end)
end

function Library:Convert(str)
    local values = {}
    for value in string.gmatch(str, "[^,]+") do
        Insert(values, tonumber(value))
    end
    if #values == 4 then
        return table.unpack(values)
    end
end

function Library:CloseElement(new_path)
    local open_element = self.CurrentOpen
    if open_element and new_path ~= open_element then
        open_element.set_visible(false)
        open_element.open = false
    end
    if new_path ~= open_element then
        self.CurrentOpen = new_path
    end
end

function Library:TryCloseColorpickerOutside()
    local open = self.CurrentOpen
    if not open or not open.items or not open.items.colorpicker_holder or not open.trigger then
        return
    end
    task.defer(function()
        task.wait()
        open = self.CurrentOpen
        if not open or not open.items or not open.items.colorpicker_holder or not open.trigger then
            return
        end
        local focused = UserInputService:GetFocusedTextBox()
        if focused and open.items.input and focused == open.items.input then
            return
        end
        if open.items.colorpicker_holder.Parent ~= self.Items then
            return
        end
        if open._suppress_colorpicker_outside_close then
            open._suppress_colorpicker_outside_close = false
            return
        end
        if self:Hovering(open.items.colorpicker_holder) or self:Hovering(open.trigger) then
            return
        end
        if open.items.footer_copy and self:Hovering(open.items.footer_copy) then
            return
        end
        if open.items.footer_bar and self:Hovering(open.items.footer_bar) then
            return
        end
        if open.items.input and self:Hovering(open.items.input) then
            return
        end
        if open.items.hue_picker and self:Hovering(open.items.hue_picker) then
            return
        end
        if open.items.alpha_gradient and self:Hovering(open.items.alpha_gradient) then
            return
        end
        if open.items.alpha_indicator and self:Hovering(open.items.alpha_indicator) then
            return
        end
        if open.items.alpha_picker and self:Hovering(open.items.alpha_picker) then
            return
        end
        if open.items.satvalpicker and self:Hovering(open.items.satvalpicker) then
            return
        end
        open.open = false
        self:CloseElement(nil)
    end)
end

--[[ Colorpicker opts (AddColorpicker / MountColorpicker):
        color | Color | defaultColor | DefaultColor  â€” Color3, default swatch + initial value
        alpha | Alpha  â€” 0..1 opacity (1 = solid). Ignored if transparency is set.
        transparency | Transparency  â€” Roblox style 0 = opaque, 1 = invisible; wins over alpha
        flag â€” config key; auto if omitted
        callback | Callback | onChange | OnChange â€” (Color3 color, number transparency)
        title | name | Name | titleText | Title â€” optional picker title row
        image | Image | icon | Icon â€” glyph asset id or rbxassetid URL
        background | Background | panelBackground | PanelBackground â€” Color3 panel fill (else Rgb(30, 30, 38))
    ]]
