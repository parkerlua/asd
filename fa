    function SectionApi:AddSlider(nameOrOptions)
        local Opt = typeof(nameOrOptions) == "table" and nameOrOptions or {}
        local LabelText = typeof(nameOrOptions) == "string" and nameOrOptions or (Opt.Name or Opt.name or "Slider")
        local Flag = Opt.flag or Opt.Flag or LibraryRef:NextFlag()
        local Min = typeof(Opt.min) == "number" and Opt.min or 0
        local Max = typeof(Opt.max) == "number" and Opt.max or 100
        if Max <= Min then
            Max = Min + 1
        end
        local DefaultNum = Opt.default or Opt.Default
        if typeof(DefaultNum) ~= "number" then
            DefaultNum = Min + (Max - Min) * 0.5
        end
        DefaultNum = math.clamp(DefaultNum, Min, Max)
        local Callback = Opt.Callback or Opt.callback or function() end

        local ValueSlotW = typeof(Opt.valueWidth) == "number" and Opt.valueWidth
            or typeof(Opt.value_width) == "number" and Opt.value_width
            or 250
        local MinTitlePx = typeof(Opt.min_title_px) == "number" and Opt.min_title_px or 120

        local function FormatValue(v)
            local d = Opt.decimals or Opt.Decimals
            if typeof(d) == "number" then
                d = math.clamp(math.floor(d), 0, 4)
                if d <= 0 then
                    return tostring(math.floor(v + (v >= 0 and 0.5 or -0.5)))
                end
                local fmt = "%." .. tostring(d) .. "f"
                local s = string.format(fmt, v)
                s = s:gsub("0+$", ""):gsub("%.$", "")
                return s
