    function Library:CloseFolderFilterPopup()
        if not self._FolderFilterPopup then
            return
        end
        if not self._FolderFilterPopup.Visible then
            return
        end
        self._FolderFilterPopupAnimToken = (self._FolderFilterPopupAnimToken or 0) + 1
        local CloseToken = self._FolderFilterPopupAnimToken
        self:Tween(self._FolderFilterPopup, { BackgroundTransparency = 1 }, Enum.EasingStyle.Quad, 0.08)
        task.delay(0.09, function()
            if not self._FolderFilterPopup or CloseToken ~= self._FolderFilterPopupAnimToken then
                return
            end
            self._FolderFilterPopup.Visible = false
            self._FolderFilterPopup.BackgroundTransparency = 0
        end)
    end
    self._ToggleFolderFilterPopup = function()
        if not self._FolderFilterPopup then
            return
        end
        if self._FolderFilterPopup.Visible then
            self:CloseFolderFilterPopup()
            return
        end
        CloseFolderCreatePresetPopup()
        if self._RefreshFolderFilterPopupState then
            self._RefreshFolderFilterPopupState()
        end
        local ap = self._FolderFilterIconHit.AbsolutePosition
        local sz = self._FolderFilterIconHit.AbsoluteSize
        local vx = Camera.ViewportSize.X
        local vy = Camera.ViewportSize.Y
        local width = self._FolderFilterPopup.AbsoluteSize.X
        if width < 1 then
            width = 196
        end
        local x = ap.X + sz.X - width - 275
        if x < 4 then
            x = 4
        end
        if x + width > vx - 4 then
            x = math.max(4, vx - 4 - width)
        end
        local y0 = ap.Y + sz.Y + 21
        self._FolderFilterPopup.Position = Dim2(0, x, 0, y0)
        self._FolderFilterPopupAnimToken = (self._FolderFilterPopupAnimToken or 0) + 1
        self._FolderFilterPopup.BackgroundTransparency = 1
        self._FolderFilterPopup.Visible = true
        self:Tween(self._FolderFilterPopup, { BackgroundTransparency = 0 }, Enum.EasingStyle.Quad, 0.1)
        task.defer(function()
            if not self._FolderFilterPopup.Visible then
                return
            end
            local h = self._FolderFilterPopup.AbsoluteSize.Y
            if h < 1 then
                h = 1
            end
            local y = math.clamp(y0, 4, math.max(4, vy - h - 4))
            self._FolderFilterPopup.Position = Dim2(0, x, 0, y)
        end)
    end
