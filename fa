    local function UpdateContentEdgeFades()
        if not ContentScroll or not ContentScroll.Parent then
            return
        end
        local win = ContentScroll.AbsoluteWindowSize
        local canvas = ContentScroll.AbsoluteCanvasSize
        local pos = ContentScroll.CanvasPosition
        local maxY = math.max(0, canvas.Y - win.Y)
        local maxX = math.max(0, canvas.X - win.X)
        Fades.Top.Visible = maxY > 1.5 and pos.Y > 1.5
        Fades.Bottom.Visible = maxY > 1.5 and pos.Y < maxY - 1.5
        local horiz = ContentScroll.ScrollingDirection
        local allowHorizFade = horiz == Enum.ScrollingDirection.XY or horiz == Enum.ScrollingDirection.X
        Fades.Left.Visible = allowHorizFade and maxX > 1.5 and pos.X > 1.5
        Fades.Right.Visible = allowHorizFade and maxX > 1.5 and pos.X < maxX - 1.5
    end

