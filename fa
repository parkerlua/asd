        if not (cfg.sanity and LibraryRef.CurrentOpen == cfg and cfg.open) then
            LibraryRef:CloseElement(cfg)
        end
    end

    function cfg.set(color, alpha)
        if type(color) == "boolean" then
            return
        end
        if color ~= nil then
            h, s, v = color:ToHSV()
        end
        if alpha ~= nil then
            a = alpha
        end
        local Color = Hsv(h, s, v)
        local hueTrackY = items.hue_gradient.AbsoluteSize.Y - items.hue_picker.AbsoluteSize.Y
        if hueTrackY < 0 then
            hueTrackY = 0
        end
        LibraryRef:Tween(items.hue_picker, {
            Position = Dim2(0.5, -0.95, 0, hueTrackY * h),
        }, Enum.EasingStyle.Linear, 0.05)
        LibraryRef:Tween(items.alpha_picker, {
            Position = Dim2(0, (items.alpha_gradient.AbsoluteSize.X - items.alpha_picker.AbsoluteSize.X) * (1 - a), 0.5,
                -1),
        }, Enum.EasingStyle.Linear, 0.05)
        LibraryRef:Tween(items.satvalpicker, {
            Position = Dim2(
                0,
                s * (items.saturation_holder.AbsoluteSize.X - items.satvalpicker.AbsoluteSize.X),
                1,
                1 - v * (items.saturation_holder.AbsoluteSize.Y - items.satvalpicker.AbsoluteSize.Y)
            ),
