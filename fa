    local function ListConfigStemsFromDisk()
        local stems = {}
        local seen = {}
        local dir = Library.Directory .. "/configs"
        local files = nil
        if typeof(listfiles) == "function" then
            files = listfiles(dir)
        end
        if typeof(files) == "table" then
            for _, f in ipairs(files) do
                if typeof(f) == "string" then
                    local n = f:gsub("\\", "/")
                    local leaf = n:match("([^/]+)$") or n
                    if leaf:lower():match("%.cfg$") then
                        local stem = leaf:sub(1, #leaf - 4)
                        if stem ~= "" and stem ~= "Untitled" and not seen[stem] then
                            seen[stem] = true
                            Insert(stems, stem)
                        end
                    end
                end
            end
        end
        return stems
    end

    local function RefreshFolderConfigRows()
        local toRemove = {}
        for _, r in ipairs(FolderConfigRows) do
            local m = FolderConfigRowMeta[r]
            if m and m.kind == "file" then
                Insert(toRemove, r)
            end
        end
        for _, r in ipairs(toRemove) do
            RemoveFolderConfigRow(r)
        end
        local Stems = ListConfigStemsFromDisk()
        local VisibleStems = {}
        local QueryText = tostring(self.FolderSearchQuery or ""):lower()
        QueryText = QueryText:gsub("^%s+", ""):gsub("%s+$", "")
        for _, Stem in ipairs(Stems) do
            local Label = ConfigStemDisplayLabel(Stem)
            local PassesSearch = true
            if QueryText ~= "" then
                local StemLower = tostring(Stem):lower()
                local LabelLower = tostring(Label):lower()
                PassesSearch = string.find(StemLower, QueryText, 1, true) ~= nil or string.find(LabelLower, QueryText, 1, true) ~= nil
            end
            if PassesSearch and (self.FolderFilterShowDefault or Stem ~= "Default") then
                Insert(VisibleStems, Stem)
            end
        end
        table.sort(VisibleStems, function(a, b)
            local aa = tostring(a):lower()
            local bb = tostring(b):lower()
            if self.FolderFilterSort == "Z_A" then
                return aa > bb
            end
            return aa < bb
        end)
        local LayoutOrder = 1
        for _, Stem in ipairs(VisibleStems) do
            local Label = ConfigStemDisplayLabel(Stem)
            CreateFolderConfigRow(FolderConfigStack, "folder_cfg_" .. tostring(LayoutOrder), LayoutOrder, Label, {
                kind = "file",
                stem = Stem,
                label = Label,
            })
            LayoutOrder = LayoutOrder + 1
        end
        ApplyFolderConfigActiveOutline()
        SyncFolderPopupBounds()
    end

    Library._RefreshFolderConfigRows = RefreshFolderConfigRows

    Library._RefreshOwnerPresetRows = function()
        local toRemove = {}
        for _, r in ipairs(FolderConfigRows) do
            local m = FolderConfigRowMeta[r]
            if m and m.kind == "owner_preset" then
                Insert(toRemove, r)
            end
        end
        for _, r in ipairs(toRemove) do
            RemoveFolderConfigRow(r)
        end
        local presets = Library.OwnerPresets
        if typeof(presets) ~= "table" then
            presets = {}
            Library.OwnerPresets = presets
        end
        local lo = 1
        for _, preset in ipairs(presets) do
            if typeof(preset) == "table" then
                local payload = preset.Json
                local label = tostring(preset.Name or ("Preset " .. tostring(lo)))
                if typeof(payload) == "string" and payload ~= "" then
                    local ownerRow = CreateFolderConfigRow(self._OwnerPresetsStack, "owner_preset_" .. tostring(lo), lo, label, {
                        kind = "owner_preset",
                        label = label,
                        ownerPresetId = preset.Id,
                        hideMenu = true,
                        onSelect = function()
                            self._ActiveOwnerPresetId = preset.Id
                            Library.ActiveConfigName = nil
                            FolderConfigSelect(nil)
                            Library:LoadConfig(payload)
                        end,
                    })
                    if ownerRow then
                        for _, gui in ipairs(ownerRow:GetDescendants()) do
                            if gui:IsA("GuiObject") then
                                gui.ZIndex = gui.ZIndex + 210
                            end
                        end
                        ownerRow.ZIndex = ownerRow.ZIndex + 210
                    end
                    lo = lo + 1
                end
            end
        end
        ApplyOwnerPresetActiveOutline()
        if self._SyncOwnerPresetsPopupBounds then
            self._SyncOwnerPresetsPopupBounds()
        end
        if self._UpdateOwnerPresetsScrollHeight then
            self._UpdateOwnerPresetsScrollHeight()
            task.defer(function()
                if self._UpdateOwnerPresetsScrollHeight then
                    self._UpdateOwnerPresetsScrollHeight()
                end
            end)
        end
    end

