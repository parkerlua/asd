local Fonts
do
    local function RegisterFont(Name, Weight, Style, Asset)
            local TtfPath = Library.Directory .. "/fonts/" .. Asset.Id
        if not isfile(TtfPath) then
            writefile(TtfPath, Asset.Font)
        end

            local FacePath = Library.Directory .. "/fonts/" .. Name .. ".font"
        if isfile(FacePath) then
            delfile(FacePath)
        end

        local ttfAsset = getcustomasset(TtfPath)
        if typeof(ttfAsset) ~= "string" then
            ttfAsset = "rbxassetid://" .. tostring(ttfAsset)
        end

        local Data = {
            name = Name,
            faces = {
                {
                    name = "Normal",
                    weight = Weight,
                    style = Style,
                    assetId = ttfAsset,
                },
            },
        }

        writefile(FacePath, HttpService:JSONEncode(Data))

        return getcustomasset(FacePath)
    end

