    local FolderConfigRowStrokeConns = {}

    local function ConfigRowStrokeEaseOutQuad(t)
        return 1 - (1 - t) * (1 - t)
    end
    local function ConfigRowStrokeEaseInQuad(t)
        return t * t
    end

    local function CancelFolderConfigRowStrokeAnim(row)
        local c = FolderConfigRowStrokeConns[row]
        if c then
            c:Disconnect()
            FolderConfigRowStrokeConns[row] = nil
        end
    end

    local function CancelAllFolderConfigRowStrokeAnims()
        for row, c in pairs(FolderConfigRowStrokeConns) do
            if c then
                c:Disconnect()
            end
            FolderConfigRowStrokeConns[row] = nil
        end
        for _, r in ipairs(FolderConfigRows) do
            local s = r:FindFirstChild("select_stroke")
            if s and s:IsA("UIStroke") then
                s.Thickness = 0
            end
        end
    end

    Library._CancelFolderConfigRowStrokes = CancelAllFolderConfigRowStrokeAnims

    local function AnimateFolderConfigRowStroke(row, targetThickness, duration, easeFn)
        CancelFolderConfigRowStrokeAnim(row)
        if not row.Parent then
            return
        end
        local stroke = row:FindFirstChild("select_stroke")
        if not stroke or not stroke:IsA("UIStroke") then
            return
        end
        local from = stroke.Thickness
        if math.abs(from - targetThickness) < 0.02 then
            stroke.Thickness = targetThickness
            return
        end
        local t0 = tick()
        FolderConfigRowStrokeConns[row] = RunService.Heartbeat:Connect(function()
            if not stroke.Parent then
                CancelFolderConfigRowStrokeAnim(row)
                return
            end
            local a = math.clamp((tick() - t0) / duration, 0, 1)
            local u = easeFn(a)
            stroke.Thickness = from + (targetThickness - from) * u
            if a >= 1 then
                CancelFolderConfigRowStrokeAnim(row)
                stroke.Thickness = targetThickness
            end
        end)
    end

