    local function ComputePanelScale()
        local cam = workspace.CurrentCamera
        if not cam then
            return 1
        end
        local shortSide = math.min(cam.ViewportSize.X, cam.ViewportSize.Y)
        if shortSide <= 0 then
            return 1
        end
        local margin = 28
        local design = 900
        if UserInputService.TouchEnabled then
            return math.clamp((shortSide - margin) / design, 0.45, 1)
        end
        if shortSide < 720 then
            return math.clamp((shortSide - margin) / design, 0.55, 1)
        end
        return 1
    end

