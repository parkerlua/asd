        local r8 = math.floor(c.R * 255 + 0.5)
        local g8 = math.floor(c.G * 255 + 0.5)
        local b8 = math.floor(c.B * 255 + 0.5)
        local op = math.floor((1 - transparency) * 255 + 0.5)
        return string.upper(string.format("%02X%02X%02X%02X", r8, g8, b8, op))
    end

    local function ParseHex8(str)
        str = str:gsub("%s", ""):upper()
        if #str ~= 8 or not str:match("^%x%x%x%x%x%x%x%x$") then
            return nil
        end
        local r = tonumber(str:sub(1, 2), 16)
        local g = tonumber(str:sub(3, 4), 16)
        local b = tonumber(str:sub(5, 6), 16)
        local op = tonumber(str:sub(7, 8), 16)
        if not (r and g and b and op) then
