        local grad = items.alpha_indicator:FindFirstChildOfClass("UIGradient")
        if grad then
            grad.Color = ColorSequence.new({ ColorSequenceKeypoint.new(0, Rgb(255, 255, 255)), ColorSequenceKeypoint.new(
