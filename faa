        local ActiveFg = Theme.Default
        for i, Btn in ipairs(MT.Buttons) do
            local On = i == MT.ActiveIndex
            local Img = Btn:FindFirstChild("Icon")
            local Title = Btn:FindFirstChild("Title")
            if Title and Title:IsA("TextLabel") then
