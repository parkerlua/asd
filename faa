    self:CloseDropdownIfAny()
    self.CurrentDropdown = nil

    local Cp = self.CurrentColorpicker
    if Cp and typeof(Cp.set_visible) == "function" then
        Cp.open = false
        Cp.set_visible(false, true)
    end
    self.CurrentColorpicker = nil

    if typeof(self.TooltipLayers) == "table" then
        for _, TooltipEntry in pairs(self.TooltipLayers) do
            if typeof(TooltipEntry) == "table" and TooltipEntry.MoveConn then
                TooltipEntry.MoveConn:Disconnect()
                TooltipEntry.MoveConn = nil
            end
        end
        self.TooltipLayers = {}
    end

    local Conns = self.Connections
    if typeof(Conns) == "table" then
        for Index = 1, #Conns do
            local Conn = Conns[Index]
            if Conn ~= nil then
                Conn:Disconnect()
            end
        end
    end
    self.Connections = {}

    local KB = self.KeybindList
    if typeof(KB) == "table" then
        if KB.Gui and KB.Gui.Parent then
            KB.Gui:Destroy()
        end
        KB.Gui = nil
        KB.Root = nil
        KB.Rows = nil
        KB.HeaderTitle = nil
