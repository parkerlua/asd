    local function ApplySectionButtonPressColor(Btn, IdleBg)
        local tiPress = TweenInfo.new(0.06, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        local tiRelease = TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        local bgTween

        local function TweenBg(TargetColor, UsePressTween)
            if bgTween then
                bgTween:Cancel()
            end
            bgTween = TweenService:Create(
                Btn,
                UsePressTween and tiPress or tiRelease,
                { BackgroundColor3 = TargetColor }
            )
            bgTween:Play()
        end

        LibraryRef:Connection(Btn.MouseButton1Down, function()
            TweenBg(Theme.Inline, true)
        end)
        LibraryRef:Connection(Btn.MouseButton1Up, function()
            TweenBg(IdleBg, false)
        end)
        LibraryRef:Connection(Btn.MouseLeave, function()
            TweenBg(IdleBg, false)
        end)
    end

    local function WireSectionTextButton(Btn, getLabelText, Callback, ConfirmNeeded, getConfirmText)
        if typeof(getLabelText) ~= "function" then
            local static = tostring(getLabelText or "")
            getLabelText = function()
                return static
            end
        end
        getConfirmText = typeof(getConfirmText) == "function" and getConfirmText
            or function()
                return "Are you sure?"
            end
        local pending = false
        local resetSeq = 0

        local function EndPending()
            pending = false
            Btn.Text = getLabelText()
        end

        local function ArmResetTimer()
            resetSeq = resetSeq + 1
            local seq = resetSeq
            task.spawn(function()
                task.wait(5)
                if seq == resetSeq and pending then
                    EndPending()
                end
            end)
        end

        LibraryRef:Connection(Btn.MouseButton1Click, function()
            if ConfirmNeeded then
                if not pending then
                    pending = true
                    Btn.Text = getConfirmText()
                    ArmResetTimer()
                    return
                end
                EndPending()
            end
            Callback()
        end)

        LibraryRef:RegisterLangUpdater(function()
            if not Btn.Parent then
                return
            end
            if pending then
                Btn.Text = getConfirmText()
            else
                Btn.Text = getLabelText()
            end
        end)
    end

