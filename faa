    local DefaultHeaderStripImage = "rbxassetid://115638220899181"
    function WindowObject:SetHeaderImage(Asset)
        local s = tostring(Asset or ""):gsub("^%s+", ""):gsub("%s+$", "")
        if s == "" then
            HeaderImage.Image = DefaultHeaderStripImage
            return
        end
        if
            string.sub(s, 1, 13) == "rbxassetid://"
            or string.sub(s, 1, 11) == "rbxthumb://"
            or string.sub(s, 1, 7) == "http://"
            or string.sub(s, 1, 8) == "https://"
        then
            HeaderImage.Image = s
            return
        end
        if string.match(s, "^%d+$") then
            HeaderImage.Image = "rbxassetid://" .. s
            return
        end
        HeaderImage.Image = s
    end

