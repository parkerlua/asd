    Card.Position = NewUDim2(0, NOTIFY_OFF_X, 0, TargetY.Offset)
    local TargetPos = NewUDim2(0, 0, 0, TargetY.Offset)
    self:Tween(Card, { Position = TargetPos }, Enum.EasingStyle.Quad, 0.38)

    local Closed = false
    local function CloseNow()
        if Closed then
            return
        end
        Closed = true
        for i, Item in ipairs(self.ToastQue) do
            if Item == Entry then
                Remove(self.ToastQue, i)
                break
            end
        end
        self:Tween(Card, { Position = NewUDim2(0, NOTIFY_OFF_X, 0, Card.Position.Y.Offset) }, Enum.EasingStyle.Quad, 0.2)
        task.delay(0.22, function()
            if Card and Card.Parent then
                Card:Destroy()
            end
            self:RefreshNotificationsLayout(true)
        end)
    end

    if showStepBar then
        Entry._notifyMaxStep = MaxStepVal
    end

    function Entry:ChangeTitle(t)
