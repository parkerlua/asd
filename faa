function Library:SetAccentColor(Color3Value)
    if typeof(Color3Value) ~= "Color3" then
        return
    end
    Palette.Default.ActiveBg = Color3Value
    Palette.Default.Glow = DeriveAccentGlow(Color3Value)
    if typeof(self._RefreshAccentImpl) == "function" then
        self._RefreshAccentImpl()
    end
    for _, Fn in ipairs(self.AccentUpdaters) do
        Fn()
    end
    self.KeybindList:Refresh()
end

-- Updates a single `Palette.Default` entry and reapplies theme (accent uses `SetAccentColor` for glow).
function Library:SetPaletteColor(Key, Color3Value)
    if typeof(Color3Value) ~= "Color3" or type(Key) ~= "string" then
        return
    end
    if Palette.Default[Key] == nil then
        return
    end
    if Key == "ActiveBg" then
        self:SetAccentColor(Color3Value)
        return
    end
    Palette.Default[Key] = Color3Value
    if typeof(self._RefreshAccentImpl) == "function" then
        self._RefreshAccentImpl()
    end
    for _, Fn in ipairs(self.AccentUpdaters) do
        Fn()
    end
    if self.KeybindList and typeof(self.KeybindList.Refresh) == "function" then
        self.KeybindList:Refresh()
    end
end

