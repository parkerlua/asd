            LayoutOrder = 3,
        })

        self:Connection(TrackHit.InputBegan, function(input)
            if VideoDisableBinding:IsDisabled() then
                return
            end
            if
                input.UserInputType ~= Enum.UserInputType.MouseButton1
                and input.UserInputType ~= Enum.UserInputType.Touch
            then
                return
            end
            stopScrubDrag()
            scrubDragging = true
            local x = input.Position.X
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                x = UserInputService:GetMouseLocation().X
            end
            applyScrubScreenX(x)
            scrubEndConn = UserInputService.InputEnded:Connect(function(inp)
                if
                    inp.UserInputType == Enum.UserInputType.MouseButton1
                    or inp.UserInputType == Enum.UserInputType.Touch
                then
                    stopScrubDrag()
                end
            end)
        end)

        renderConn = self:Connection(RunService.RenderStepped, function()
            if not VideoHost.Parent or not ScrubRow or not ScrubRow.Parent then
                return
            end
            -- Only rewrite TimePosition while input is held; avoids stuck drag fighting playback.
            if scrubDragging then
                local mb1 = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
                local touches = UserInputService:GetTouches()
                if mb1 or #touches > 0 then
                    local x = UserInputService:GetMouseLocation().X
                    if #touches > 0 then
                        x = touches[1].Position.X
                    end
                    applyScrubScreenX(x)
                else
                    stopScrubDrag()
                end
            end
            local dur = VideoHost.TimeLength
            local t = VideoHost.TimePosition
            CurLbl.Text = FormatVideoTime(t)
            DurLbl.Text = dur > 0 and FormatVideoTime(dur) or "--:--"
            local frac = dur > 0 and MathClamp(t / dur, 0, 1) or 0
            TrackFill.Size = NewUDim2(frac, 0, 1, 0)
            local tw = TrackWrap.AbsoluteSize.X
            local hw = TrackThumb.AbsoluteSize.X * 0.5
            if tw > hw * 2 + 2 then
                local cx = MathClamp(frac * tw, hw, tw - hw)
                TrackThumb.Position = NewUDim2(0, cx, 0.5, 1)
            else
                TrackThumb.Position = NewUDim2(0.5, 0, 0.5, 1)
            end
        end)

        self:Connection(SectionRow.Destroying, function()
            stopScrubDrag()
            if renderConn then
                renderConn:Disconnect()
                renderConn = nil
            end
        end)

        self:Connection(VideoHost:GetPropertyChangedSignal("TimeLength"), function()
            if not DurLbl or not DurLbl.Parent then
                return
            end
            local d = VideoHost.TimeLength
            DurLbl.Text = d > 0 and FormatVideoTime(d) or "--:--"
        end)
    end

    self:Connection(VideoHost:GetPropertyChangedSignal("Playing"), function()
        Playing = VideoHost.Playing
    end)

    Insert(self.AccentUpdaters, function()
        if VideoClip.Parent then
            VideoClip.BackgroundColor3 = Theme.Inline
        end
        VideoDisableBinding:SyncDimAfterTheme()
        if TrackBg and TrackBg.Parent then
            TrackBg.BackgroundColor3 = Theme.Inline:Lerp(Theme.TextMuted, 0.5)
        end
        if TrackFill and TrackFill.Parent then
            TrackFill.BackgroundColor3 = Theme.ActiveBg
        end
        if TrackThumb and TrackThumb.Parent then
            TrackThumb.BackgroundColor3 = Theme.TextMuted:Lerp(Theme.TextBody, 0.42)
        end
    end)

    local VideoApi = { Frame = VideoHost, Row = SectionRow }
    function VideoApi:SetHeight(H)
        H = tonumber(H) or Height
        Height = MathClamp(H, 48, 720)
        VideoClip.Size = NewUDim2(1, 0, 0, Height)
    end

    function VideoApi:SetVideo(Asset)
        VideoAsset = NormalizeVideoAsset(Asset)
        VideoHost.Video = VideoAsset ~= "" and VideoAsset or ""
    end

    function VideoApi:SetLooped(On)
        Looped = On == true
        VideoHost.Looped = Looped
    end

    function VideoApi:SetVolume(V)
        V = tonumber(V)
        if V == nil then
            return
        end
        Volume = MathClamp(V, 0, 1)
        VideoHost.Volume = Volume
    end

    function VideoApi:SetPlaying(On)
        Playing = On == true
        VideoHost.Playing = Playing
    end

    function VideoApi:Play()
        VideoHost.Playing = true
        Playing = true
    end

    function VideoApi:Pause()
        VideoHost.Playing = false
        Playing = false
    end

    function VideoApi:TogglePlayPause()
        if VideoDisableBinding:IsDisabled() then
            return
        end
        VideoHost.Playing = not VideoHost.Playing
    end

    function VideoApi:IsPlaying()
        return VideoHost.Playing == true
    end

    function VideoApi:SetVisible(On)
        ElementVisible = On ~= false
        SectionRow.Visible = ElementVisible
    end

    function VideoApi:SetDisabled(On)
        VideoDisableBinding:SetDisabled(On)
    end

    function VideoApi:IsDisabled()
        return VideoDisableBinding:IsDisabled()
    end

    function VideoApi:GetTimePosition()
        return VideoHost.TimePosition
    end

    function VideoApi:GetDuration()
        return VideoHost.TimeLength
    end

    function VideoApi:Seek(Seconds)
        local dur = VideoHost.TimeLength
        if dur <= 0 then
            return
        end
        local t = MathClamp(tonumber(Seconds) or 0, 0, dur)
        VideoHost.TimePosition = t
    end

    self.Flags[Id] = VideoApi
    Callback(VideoApi)
    return VideoApi
end

function Library:_ParseSectionImageVector2(V, Default)
    Default = Default or NewVector2(0, 0)
    if typeof(V) == "Vector2" then
        return V
    end
    if type(V) == "table" then
        local x = tonumber(V[1] or V.X or V.x) or 0
        local y = tonumber(V[2] or V.Y or V.y) or 0
        return NewVector2(x, y)
    end
    return Default
end

function Library:_ParseSectionImageScaleType(V)
    if typeof(V) == "EnumItem" and V.EnumType == Enum.ScaleType then
        return V
    end
    local s = type(V) == "string" and string.lower(V) or ""
    if s == "stretch" then
        return Enum.ScaleType.Stretch
    end
    if s == "crop" then
        return Enum.ScaleType.Crop
    end
    if s == "tile" then
        return Enum.ScaleType.Tile
    end
    if s == "fit" then
        return Enum.ScaleType.Fit
    end
    return Enum.ScaleType.Fit
end

-- Section image row (asd-style AddImage): bordered clip, ImageLabel, optional sprite rect + tint.
function Library:_MountSectionImage(Scrolling, Id, Opt)
    Opt = typeof(Opt) == "table" and Opt or {}

    local Height = tonumber(Opt.Height or Opt.height) or 200
    Height = MathClamp(Height, 32, 720)
    local ImageSpec = Opt.Image or Opt.image or Opt.Asset or Opt.asset or Opt.Icon or Opt.icon or ""
    local Resolved = self:ResolveColorpickerImage(ImageSpec)
    local ScaleType = self:_ParseSectionImageScaleType(Opt.ScaleType or Opt.scaleType)
    local Tint = Opt.ImageColor3 or Opt.imageColor3 or Opt.Color or Opt.color
    if typeof(Tint) ~= "Color3" then
        Tint = FromRgb(255, 255, 255)
    end
    local ImgTransparency = tonumber(Opt.ImageTransparency or Opt.imageTransparency or Opt.Transparency or
    Opt.transparency)
    if ImgTransparency == nil then
