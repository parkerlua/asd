    local function RowSearchBlob(row)
        local n = row.Name
        if n == "toggle_row" then
            local t = row:FindFirstChild("toggle_label", true)
            local base = t and t.Text or ""
            local parent = row.Parent
            if parent then
                local ch = parent:GetChildren()
                for i, c in ipairs(ch) do
                    if c == row then
                        local nxt = ch[i + 1]
                        if nxt and nxt:IsA("GuiObject") and string.sub(nxt.Name, -11) == "_deps_outer" then
                            local extra = RowSearchBlob(nxt)
                            if extra ~= "" then
                                return base .. " " .. extra
                            end
                        end
                        break
                    end
                end
            end
            return base
        elseif n == "checkbox_row" then
            local t = row:FindFirstChild("checkbox_label", true)
            local base = t and t.Text or ""
            local parent = row.Parent
            if parent then
                local ch = parent:GetChildren()
                for i, c in ipairs(ch) do
                    if c == row then
                        local nxt = ch[i + 1]
                        if nxt and nxt:IsA("GuiObject") and string.sub(nxt.Name, -11) == "_deps_outer" then
                            local extra = RowSearchBlob(nxt)
                            if extra ~= "" then
                                return base .. " " .. extra
                            end
                        end
                        break
                    end
                end
            end
            return base
        elseif n == "colorpicker_row" then
            local t = row:FindFirstChild("colorpicker_label", true)
            return t and t.Text or ""
        elseif n == "keybind_row" then
            local t = row:FindFirstChild("keybind_label", true)
            return t and t.Text or ""
        elseif n == "slider_row" then
            local t = row:FindFirstChild("slider_label", true)
            return t and t.Text or ""
        elseif n == "dropdown_row" then
            local t = row:FindFirstChild("dropdown_label", true)
            local v = row:FindFirstChild("dropdown_value_text", true)
            local ts = t and t.Text or ""
            local vs = v and v.Text or ""
            if vs ~= "" then
                return ts .. " " .. vs
            end
            return ts
        elseif n == "section_button_row" then
            local b = row:FindFirstChild("section_button")
            return b and b.Text or ""
        elseif n == "section_multibutton_row" then
            local parts = {}
            for _, c in row:GetChildren() do
                if c:IsA("TextButton") then
                    Insert(parts, c.Text)
                end
            end
            return Concat(parts, " ")
        elseif n == "section_image_row" then
            return ""
        elseif n == "section_label_row" then
            local t = row:FindFirstChild("section_label", true)
            return t and t.Text or ""
        elseif n == "section_link_label_row" then
            local t = row:FindFirstChild("section_label", true)
            return t and t.Text or ""
        elseif n == "section_divider_text_wrap" then
            local t = row:FindFirstChild("section_divider_text_label", true)
            return t and t.Text or ""
        elseif n == "section_divider_row" then
            return ""
        elseif n == "dep_textinput_row" then
            local t = row:FindFirstChild("dep_textinput_label", true)
            local box = row:FindFirstChild("dep_textinput_box", true)
            local ts = t and t.Text or ""
            local bs = box and box.Text or ""
            if bs ~= "" then
                return ts .. " " .. bs
            end
            return ts
        elseif string.sub(n, -11) == "_deps_outer" then
            local inner = row:FindFirstChild("deps_inner_stack")
            if inner then
                local parts = {}
                for _, ch in ipairs(inner:GetChildren()) do
                    if ch:IsA("GuiObject") then
                        local s = RowSearchBlob(ch)
                        if s ~= "" then
                            Insert(parts, s)
                        end
                    end
                end
                return Concat(parts, " ")
            end
            return ""
        end
        return ""
    end

    local function ApplySectionSearch(sectionRoot, norm)
        local scrolling = sectionRoot:FindFirstChild("scrolling", true)
        if not scrolling then
            return
        end
        local titleEl = sectionRoot:FindFirstChild("section_title", true)
        local titleText = titleEl and string.lower(tostring(titleEl.Text)) or ""
        local outline = sectionRoot:FindFirstChild("outline")
        local hasCollapse = sectionRoot:GetAttribute("SectionCollapsible") == true

        local function IsDepsOuterRow(row)
            return row:IsA("GuiObject") and string.sub(row.Name, -11) == "_deps_outer"
        end

        local function syncChevronExpanded(exp)
            local ch = sectionRoot:FindFirstChild("section_chevron", true)
            if ch and ch:IsA("ImageLabel") then
                ch.Image = exp and LibRef:TabIcon("chevron-up") or LibRef:TabIcon("chevron-down")
            end
        end

        if norm == "" then
            sectionRoot.Visible = true
            for _, row in ipairs(scrolling:GetChildren()) do
                if row:IsA("GuiObject") and not IsDepsOuterRow(row) then
                    row.Visible = true
                end
            end
            if hasCollapse and outline then
                local exp = sectionRoot:GetAttribute("SectionExpanded")
                if exp == nil then
                    exp = true
                end
                outline.Visible = exp
                syncChevronExpanded(exp)
            end
            return
        end

        if string.find(titleText, norm, 1, true) then
            sectionRoot.Visible = true
            for _, row in ipairs(scrolling:GetChildren()) do
                if row:IsA("GuiObject") and not IsDepsOuterRow(row) then
                    row.Visible = true
                end
            end
            if hasCollapse and outline then
                outline.Visible = true
                syncChevronExpanded(true)
            end
            return
        end

        local anyRow = false
        for _, row in ipairs(scrolling:GetChildren()) do
            if row:IsA("GuiObject") then
                local match = false
                if row.Name == "section_divider_row" then
                    match = false
                else
                    local blob = string.lower(RowSearchBlob(row))
                    if blob ~= "" then
                        match = string.find(blob, norm, 1, true) ~= nil
                    end
                end
                row.Visible = match
                if match then
                    anyRow = true
                end
            end
        end
        sectionRoot.Visible = anyRow
        if hasCollapse and outline and sectionRoot.Visible then
            outline.Visible = true
            syncChevronExpanded(true)
        end
    end

    local function ApplySearchToSectionsHostContent(host, norm)
        if not host then
            return
        end
        for _, child in ipairs(host:GetChildren()) do
            if child.Name ~= "UIListLayout" and child.Name ~= "UIPadding" then
                if child.Name == "SectionPairRow" then
                    for _, slotName in ipairs({ "LeftSlot", "RightSlot" }) do
                        local slot = child:FindFirstChild(slotName)
                        if slot then
                            for _, sec in ipairs(slot:GetChildren()) do
                                if sec.Name == "Section" then
                                    ApplySectionSearch(sec, norm)
                                end
                            end
                        end
                    end
                elseif child.Name == "Section" then
                    ApplySectionSearch(child, norm)
                end
            end
        end
    end

