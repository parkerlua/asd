    local function ReadPingText()
        local Network = Stats.Network
        local ServerStats = Network and Network.ServerStatsItem
        local PingItem = ServerStats and ServerStats["Data Ping"]
        if not PingItem then
            return "--"
        end
        local Raw = tostring(PingItem:GetValueString() or "")
        local Digits = string.match(Raw, "%d+")
        local Value = Digits or Raw
        if Value and Value ~= "" then
            return Value
        end
        return "--"
    end

    local PadOuterLeft = 12
    local PadOuterRight = 14

    local WmFlagShowTitle = "cfg_watermark_show_title"
    local WmFlagShowGame = "cfg_watermark_show_game"
    local WmFlagShowFps = "cfg_watermark_show_fps"
    local WmFlagShowPing = "cfg_watermark_show_ping"
    local WmFlagShowTime = "cfg_watermark_show_time"
    local WmFlagCustomTitle = "cfg_watermark_custom_title"

    local function WmFlagOn(FlagName, DefaultOn)
        local v = Library.Flags and Library.Flags[FlagName]
        if v == nil then
            return DefaultOn
        end
        return v == true
    end

    local function RefreshWatermarkLayout()
        task.defer(function()
            if not Card.Parent or not TitleBadge.Parent or not InfoLbl.Parent then
                return
            end
            local BadgeShown = TitleBadge.Visible and TitleText.Text ~= ""
            local Gap = (BadgeShown and InfoLbl.Text ~= "") and 14 or 0
            local TitleWidth = BadgeShown and math.max(0, TitleBadge.AbsoluteSize.X) or 0
            local InfoWidth = math.max(0, InfoLbl.TextBounds.X)
            TitleBadge.Position = NewUDim2(0, 0, 0.5, 0)
            InfoLbl.Position = NewUDim2(0, TitleWidth + Gap, 0.5, 0)
            local Width = math.max(210, MathFloor(PadOuterLeft + TitleWidth + Gap + InfoWidth + PadOuterRight))
            Card.Size = NewUDim2(0, Width, 0, 40)
        end)
    end

    local function RefreshWatermarkText()
        if Library.Flags ~= nil and Library.Flags[WmFlagCustomTitle] ~= nil then
            TitleText.Text = tostring(Library.Flags[WmFlagCustomTitle])
        else
            TitleText.Text = tostring(Library._WatermarkTitleFallback or TitleStr or "Rift")
        end

        TitleBadge.Visible = WmFlagOn(WmFlagShowTitle, true)

        local Parts = {}
        if WmFlagOn(WmFlagShowGame, true) then
            if WatermarkGameName == "UGC" then
                WatermarkGameName = ResolveWatermarkPlaceName()
            end
            Insert(Parts, WatermarkGameName)
        end
        if WmFlagOn(WmFlagShowFps, true) then
            Insert(Parts, "FPS " .. tostring(MathMax(0, MathFloor(WatermarkFps + 0.5))))
        end
        if WmFlagOn(WmFlagShowPing, true) then
            Insert(Parts, tostring(WatermarkPing) .. " PING")
        end
        if WmFlagOn(WmFlagShowTime, true) then
            local TimeText = ""
            if DateTime then
                TimeText = DateTime.now():FormatLocalTime("LT", "en-us") or ""
            end
            if TimeText == "" and typeof(os) == "table" and os.date then
                TimeText = tostring(os.date("%I:%M %p"))
            end
            if TimeText ~= "" then
                Insert(Parts, TimeText)
            end
        end
        InfoLbl.Text = table.concat(Parts, "    ")
        RefreshWatermarkLayout()
    end

    self:Connection(RunService.RenderStepped, function(dt)
        if dt > 0 then
            local InstantFps = 1 / dt
            WatermarkFps = (WatermarkFps <= 0) and InstantFps or ((WatermarkFps * 0.85) + (InstantFps * 0.15))
        end
        local Now = tick()
        if Now - LastWMUpdate >= 0.25 then
            LastWMUpdate = Now
            WatermarkPing = ReadPingText()
            RefreshWatermarkText()
        end
    end)

    RefreshWatermarkText()

    task.defer(function()
        if not Card.Parent then
            return
        end
        local vx = Camera.ViewportSize.X
        local w = MathMax(1, Card.AbsoluteSize.X)
        Card.Position = NewUDim2(0, MathFloor((vx - w) / 2), 0, 16)
    end)

    self._WatermarkGui = Gui
    self._WatermarkRefreshLayout = RefreshWatermarkLayout
    self._WatermarkRefreshText = RefreshWatermarkText

    return self
end

