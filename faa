            FontFace = Library.Font,
            Text = "0:00",
            TextColor3 = Theme.TextMuted,
            TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextYAlignment = Enum.TextYAlignment.Center,
            LayoutOrder = 1,
        })

        local TrackWrap = self:CreateInstance("Frame", {
            Parent = ScrubRow,
            Name = "video_track_wrap",
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Size = NewUDim2(1, -96, 0, 18),
            LayoutOrder = 2,
            ClipsDescendants = false,
        })
        TrackWrapRef = TrackWrap

        TrackBg = self:CreateInstance("Frame", {
            Parent = TrackWrap,
            Name = "video_track_bg",
            AnchorPoint = NewVector2(0.5, 0.5),
            Position = NewUDim2(0.5, 0, 0.5, 1),
            Size = NewUDim2(1, 0, 0, 5),
            BackgroundColor3 = videoTrackRailColor(),
            BorderSizePixel = 0,
            ClipsDescendants = true,
            ZIndex = 1,
        })
        self:CreateInstance("UICorner", {
            Parent = TrackBg,
            CornerRadius = NewUDim(0, 3),
        })

        TrackFill = self:CreateInstance("Frame", {
            Parent = TrackBg,
            Name = "video_track_fill",
            BackgroundColor3 = Theme.ActiveBg,
            BorderSizePixel = 0,
            Size = NewUDim2(0, 0, 1, 0),
            ZIndex = 2,
        })
        self:CreateInstance("UICorner", {
