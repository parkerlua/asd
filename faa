                    end
                    if SliderDis:IsDisabled() then
                        StopDrag()
                        return
                    end
                    Commit(ValueFromAbsoluteX(UserInputService:GetMouseLocation().X))
                end)
            else
                moveConn = UserInputService.InputChanged:Connect(function(In)
                    if not Dragging then
                        return
                    end
                    if SliderDis:IsDisabled() then
                        StopDrag()
                        return
                    end
                    if In.UserInputType == Enum.UserInputType.Touch then
                        Commit(ValueFromAbsoluteX(In.Position.X))
                    end
                end)
            end
            endConn = UserInputService.InputEnded:Connect(function(In)
                if
                    In.UserInputType == Enum.UserInputType.MouseButton1
                    or In.UserInputType == Enum.UserInputType.Touch
                then
                    StopDrag()
                end
            end)
        end

        LibraryRef:Connection(Thumb.MouseButton1Down, function()
            if SliderDis:IsDisabled() then
                return
            end
            BeginDrag(nil)
        end)
        LibraryRef:Connection(Rail.InputBegan, function(Input)
            if SliderDis:IsDisabled() then
                return
            end
            if
                Input.UserInputType == Enum.UserInputType.MouseButton1
                or Input.UserInputType == Enum.UserInputType.Touch
            then
                Commit(ValueFromAbsoluteX(Input.Position.X))
                BeginDrag(Input)
            end
        end)

        Commit(Current)

        do
            local tb, tl = LibraryRef:_ParseTooltipParts(Opt)
            if tb ~= nil or tl ~= nil then
                Row.Active = true
            end
        end
        LibraryRef:WireTooltip(Row, Opt)

        LibraryRef:RegisterLangUpdater(function()
            if NameLabel.Parent then
                NameLabel.Text = LibraryRef:ResolveLang(LabelLang, rawLabel)
            end
        end)

        local SliderOut = {
