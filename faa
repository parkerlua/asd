function Library.KeybindList:Register(Id, Name, Key, Active, Toggleable, OnToggle, Enabled)
    EnsureKeybindList()
    if not self.Entries[Id] then
        Insert(self.OrderedIds, Id)
    end
    self.Entries[Id] = {
        Name = Name or "keybind",
        Key = Key,
        Active = Active == true,
        Toggleable = Toggleable == true,
        OnToggle = OnToggle,
        Enabled = Enabled ~= false,
    }
    self:Refresh()
end

function Library.KeybindList:Update(Id, Name, Key, Active, Toggleable, OnToggle, Enabled)
    if not self.Entries[Id] then
        self:Register(Id, Name, Key, Active, Toggleable, OnToggle, Enabled)
        return
    end
    local Entry = self.Entries[Id]
    if Name ~= nil then
        Entry.Name = Name
    end
    Entry.Key = Key
    if Active ~= nil then
        Entry.Active = Active == true
    end
    if Toggleable ~= nil then
        Entry.Toggleable = Toggleable == true
    end
    if OnToggle ~= nil then
        Entry.OnToggle = OnToggle
    end
    if Enabled ~= nil then
        Entry.Enabled = Enabled == true
    end
    self:Refresh()
end

function Library.KeybindList:Unregister(Id)
    if not self.Entries[Id] then
        return
    end
    self.Entries[Id] = nil
    for Index, EntryId in next, self.OrderedIds do
        if EntryId == Id then
            Remove(self.OrderedIds, Index)
            break
        end
    end
    self:Refresh()
end

function Library.KeybindList:SetVisible(IsVisible)
    EnsureKeybindList()
    self.Gui.Enabled = IsVisible == nil and true or IsVisible
end

-- `game.Name` is often the literal "UGC" for UGC experiences; catalog name is readable.
local function ResolveWatermarkPlaceName()
    local PlaceId = game.PlaceId
    if typeof(PlaceId) == "number" and PlaceId > 0 then
        local ProductInfo = MarketplaceService:GetProductInfo(PlaceId, Enum.InfoType.Asset)
        if typeof(ProductInfo) == "table" then
            local PlaceName = tostring(ProductInfo.Name or "")
            if PlaceName ~= "" then
                return PlaceName
            end
        end
    end
    local raw = tostring(game.Name or "")
    if raw ~= "" then
        return raw
    end
    return "Unknown"
end

