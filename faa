    local function ResolveSectionParent(Host, Spec, TabRow)
        local SideRaw = Spec.Side or Spec.side
        local side
        if SideRaw == nil then
            side = "full"
        else
            side = string.lower(tostring(SideRaw))
        end
        if side ~= "left" and side ~= "right" then
            TabRow._SectionPairOpen = false
            TabRow._SectionPairRow = nil
            return Host
        end
        if side == "left" then
            if TabRow._SectionPairOpen then
                TabRow._SectionPairOpen = false
                TabRow._SectionPairRow = nil
            end
            local PairRow = CreateSectionPairRow(Host)
            TabRow._SectionPairRow = PairRow
            TabRow._SectionPairOpen = true
            return PairRow:FindFirstChild("LeftSlot")
        end
        if TabRow._SectionPairOpen and TabRow._SectionPairRow then
            local R = TabRow._SectionPairRow:FindFirstChild("RightSlot")
            TabRow._SectionPairOpen = false
            TabRow._SectionPairRow = nil
            return R
        end
        local PairRow = CreateSectionPairRow(Host)
        return PairRow:FindFirstChild("RightSlot")
    end

