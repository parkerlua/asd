local function KeybindListAnimateRowToggleThenRefresh(KB, EntryId, Entry)
    local RowFrame = KB.Rows:FindFirstChild("Entry_" .. EntryId)
    local Inner = RowFrame and RowFrame:FindFirstChild("RowInner")
    local Badge = Inner and Inner:FindFirstChild("KeyBadge")
    local KeyTextLbl = Badge and Badge:FindFirstChildOfClass("TextLabel")
    local NameStretchF = Inner and Inner:FindFirstChild("NameStretch")
    local ActionNameLbl = NameStretchF and NameStretchF:FindFirstChild("ActionName")
    if not (Badge and KeyTextLbl and ActionNameLbl) then
        KB:Refresh()
        return
    end
    local On = Entry.Enabled ~= false
    local TargetBg = On and Theme.ActiveBg or Theme.Control
    local TargetKeyTxt = On and Theme.ActiveFg or FromRgb(255, 255, 255)
    local TargetNameTxt = On and FromRgb(255, 255, 255) or Theme.TextBody
    local TiList = TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local TwBg = TweenService:Create(Badge, TiList, { BackgroundColor3 = TargetBg })
    TweenService:Create(KeyTextLbl, TiList, { TextColor3 = TargetKeyTxt }):Play()
    TweenService:Create(ActionNameLbl, TiList, { TextColor3 = TargetNameTxt }):Play()
    local DoneConn
    DoneConn = TwBg.Completed:Connect(function()
        if DoneConn then
            DoneConn:Disconnect()
            DoneConn = nil
        end
        KB:Refresh()
    end)
    TwBg:Play()
end

