    opts = typeof(opts) == "table" and opts or {}
    local LibRef = self
    local panelBg = opts.background or opts.Background or opts.panelBackground or opts.PanelBackground
    if typeof(panelBg) ~= "Color3" then
        panelBg = Hex("181818")
    end
    local startColor = opts.color or opts.Color or opts.defaultColor or opts.DefaultColor
    if typeof(startColor) ~= "Color3" then
        startColor = FromRgb(255, 255, 255)
    end
    local startTransparency = 0
    if opts.transparency ~= nil or opts.Transparency ~= nil then
        startTransparency = opts.transparency or opts.Transparency
    elseif opts.alpha ~= nil or opts.Alpha ~= nil then
        startTransparency = 1 - (opts.alpha or opts.Alpha)
    end
    local PickerTitleRaw = opts.title or opts.name or opts.Name or opts.titleText or opts.Title
    PickerTitleRaw = PickerTitleRaw ~= nil and tostring(PickerTitleRaw) or ""
    local PickerTitleLang = opts.Lang or opts.lang
    local PickerTitle = LibRef:ResolveLang(PickerTitleLang, PickerTitleRaw)
    local HasTitle = PickerTitle ~= ""
    local cfg = {
        flag = opts.flag or LibRef:NextFlag(),
        color = startColor,
        alpha = startTransparency,
        open = false,
        rainbow = opts.rainbow == true or opts.Rainbow == true,
        callback = opts.callback or opts.Callback or opts.onChange or opts.OnChange or function() end,
        items = {},
        interactionBlocked = nil,
    }
    local dragging_sat, dragging_hue, dragging_alpha = false, false, false
    local h, s, v = cfg.color:ToHSV()
    -- Transparency: Roblox-style (0 = solid, 1 = fully clear). Same number as `Library.Flags[cfg.flag].Transparency`.
    -- 8-char hex uses the last pair as opacity byte (FF = solid); see Hex8FromColor / ParseHex8. UI: `alpha_gradient` strip above the hex row.
    local a = cfg.alpha
    LibRef.Flags[cfg.flag] = { Color = cfg.color, Transparency = cfg.alpha, Rainbow = cfg.rainbow }
    local items = cfg.items
