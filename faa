    local function MoveMultiTabSlider(Row, Btn, UseTween)
        local MT = Row.MultiTab
        if not MT or not MT.PillSlider or not Btn or not Btn.Parent then
            return
        end
        local PillTrack = MT.PillTrack
        local slider = MT.PillSlider
        task.defer(function()
            task.wait()
            if not PillTrack or not PillTrack.Parent or not Btn.Parent then
                return
            end
            local ap = Btn.AbsolutePosition
            local as = Btn.AbsoluteSize
            local tp = PillTrack.AbsolutePosition
            local relX = ap.X - tp.X
            local trackH = PillTrack.AbsoluteSize.Y
            if trackH < 1 then
                trackH = 36
            end
            local pos = NewUDim2(0, relX, 0, 0)
            local sz = NewUDim2(0, as.X, 0, trackH)
            if UseTween then
                TweenService:Create(
                    slider,
                    TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                    {
                        Position = pos,
                        Size = sz,
                    }
                ):Play()
            else
                slider.Position = pos
                slider.Size = sz
            end
        end)
    end

