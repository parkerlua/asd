local TAB_ICON_TITLE_ALIAS = {
    combat = "sword",
    esp = "eye",
    movement = "person",
    render = "eye",
    player = "user-circle",
    misc = "gear",
    settings = "gear",
    baritone = "default",
}

local TAB_ICON_FALLBACK = "rbxassetid://88390933415082"

function Library:HttpIcon(Url)
    if type(Url) ~= "string" or Url == "" then
        return nil
    end
    if not string.match(Url, "^https?://") then
        return nil
    end
    local Fn = getcustomasset or get_custom_asset
    if type(Fn) ~= "function" or type(writefile) ~= "function" then
        return nil
    end
    self._HttpIconCache = self._HttpIconCache or {}
    local Cached = self._HttpIconCache[Url]
    if Cached then
        return Cached
    end
    local AssetDir = self.Directory .. "/Assets"
    local tail = Url:match("/([^/%?]+)%??[^/]*$") or "asset"
    tail = tail:gsub("[^%w%.%-_]", "_")
    if #tail > 96 then
        tail = tail:sub(1, 96)
    end
    local FullPath = AssetDir .. "/_http_" .. tail
    if not self:FileExists(FullPath) then
        local Body = game:HttpGet(Url)
        if type(Body) == "string" and #Body > 0 then
            writefile(FullPath, Body)
        end
    end
    if self:FileExists(FullPath) then
        local Res = Fn(FullPath)
        if type(Res) == "string" and Res ~= "" then
            self._HttpIconCache[Url] = Res
            return Res
        end
    end
    return nil
end

function Library:TabIcon(IconSpec, TitleForAlias)
    local Base = self.IconsBaseUrl
    local Fallback = TAB_ICON_FALLBACK
    if typeof(IconSpec) == "number" then
        return "rbxassetid://" .. tostring(IconSpec)
    end
    if IconSpec ~= nil then
        local s = tostring(IconSpec)
        if s ~= "" then
            if string.sub(s, 1, 13) == "rbxassetid://" or string.sub(s, 1, 11) == "rbxasset://" then
                return s
            end
            if s:match("^%d+$") then
                return "rbxassetid://" .. s
            end
            if string.match(s, "^https?://") then
                return self:HttpIcon(s) or Fallback
            end
            local lk = string.lower(s)
            local mkey = TAB_ICON_TITLE_ALIAS[lk] or lk
            local Preloaded = self.Assets[mkey]
            if type(Preloaded) == "string" and Preloaded ~= "" then
                return Preloaded
            end
            local fname = self.AssetManifest[mkey]
            if fname then
                return self:HttpIcon(Base .. fname) or Fallback
            end
        end
    end
    if TitleForAlias then
        local tk = string.lower((tostring(TitleForAlias):gsub("%s+", "")))
        local mkey = TAB_ICON_TITLE_ALIAS[tk] or "default"
        local Preloaded = self.Assets[mkey]
        if type(Preloaded) == "string" and Preloaded ~= "" then
            return Preloaded
        end
        local fname = self.AssetManifest[mkey]
        if fname then
            return self:HttpIcon(Base .. fname) or Fallback
        end
    end
    local defName = self.AssetManifest.default or "default.png"
    local DefPre = self.Assets.default
    if type(DefPre) == "string" and DefPre ~= "" then
        return DefPre
    end
    return self:HttpIcon(Base .. defName) or Fallback
end

function Library:ResolveColorpickerImage(ImgSpec)
    local Spec = ImgSpec
    if Spec == nil then
        Spec = "palette"
    end
    if typeof(Spec) == "number" then
        return "rbxassetid://" .. tostring(Spec)
    end
    local s = tostring(Spec)
    if s == "" then
        return self:TabIcon("palette")
    end
    if string.sub(s, 1, 13) == "rbxassetid://" or string.sub(s, 1, 11) == "rbxasset://" then
        return s
    end
    if string.match(s, "^https?://") then
        return self:HttpIcon(s) or self:TabIcon("palette")
    end
    if s:match("^%d+$") then
        return "rbxassetid://" .. s
    end
    return self:TabIcon(s) or self:TabIcon("palette")
end

