    AddPaletteExpandable("Toggles", {
        { "Toggle track (off)", "ToggleTrackOff" },
        { "Toggle knob (off)", "ToggleKnobOff" },
    })

    local ConfigSection = SettingsTab:AddSection("Config", { Side = "right" })
    local _cfgNameFlag = "cfg_config_name"
    if Library.Flags[_cfgNameFlag] == nil then Library.Flags[_cfgNameFlag] = "" end
    local _cfgDir = Library.Directory .. "/Configs"

    local function _cfgSerialize()
        local data = {}
        for k, v in pairs(Library.Flags) do
            local t = typeof(v)
            if t == "boolean" or t == "number" or t == "string" then
                data[k] = v
            elseif t == "EnumItem" then
                data[k] = { _t = "e", v = tostring(v) }
            elseif t == "table" then
                if typeof(v.Color) == "Color3" then
                    data[k] = { _t = "c", h = v.Color:ToHex(), tr = v.Transparency or 0 }
                else
                    local s = {}
                    for tk, tv in pairs(v) do
                        local tt = typeof(tv)
                        if tt == "boolean" or tt == "number" or tt == "string" then
                            s[tk] = tv
                        elseif tt == "EnumItem" then
                            s[tk] = tostring(tv)
                        end
                    end
                    data[k] = s
                end
            end
        end
        return HttpService:JSONEncode(data)
    end

    local function _cfgApply(json)
        local ok, data = pcall(function() return HttpService:JSONDecode(json) end)
        if not ok or type(data) ~= "table" then return end
        for k, v in pairs(data) do
            if type(v) == "table" and v._t == "c" and v.h then
                Library.Flags[k] = { Color = Color3.fromHex(v.h), Transparency = v.tr or 0 }
            elseif type(v) ~= "table" then
                Library.Flags[k] = v
            else
                Library.Flags[k] = v
            end
            local setter = Library.ConfigFlags[k]
            if typeof(setter) == "function" then pcall(setter, Library.Flags[k]) end
        end
    end

    local _cfgNameInput = nil
    local _cfgFileDrop = nil

    local function _cfgListFiles()
        if type(listfiles) ~= "function" then return {} end
        if type(makefolder) == "function" then pcall(makefolder, _cfgDir) end
        local ok, files = pcall(listfiles, _cfgDir)
        if not ok or type(files) ~= "table" then return {} end
        local names = {}
        for _, f in ipairs(files) do
            local name = tostring(f):match("([^/\\]+)%.cfg$")
            if name then Insert(names, name) end
        end
        return names
    end

