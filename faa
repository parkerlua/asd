--[[
    TabCategorie only adds a grey label row in the sidebar. Each AddTab after it counts as
    part of that group until you call TabCategorie again. Write them top to bottom and the
    nav matches that order.

    TabCategorie hands back Win for chaining. AddTab hands back the tab API. Keeping the
    Win result in the table is just for you, the library does not care about those keys.
]]
local TabSection = {
    General = Win:TabCategorie("General"),
    Combat = Win:AddTab({ Title = "Combat", Icon = "sword" }),
    Visuals = Win:AddTab({ Title = "Visuals", Icon = "eye" }),
    Player = Win:AddTab({ Title = "Player", Icon = "person" }),
    Other = Win:TabCategorie("Other"),
    Misc = Win:AddTab({ Title = "Misc", Icon = "default" }),
}

-- Drops in the stock Settings tab (palette, language, font, window stuff, watermark, etc).
-- If you pass this table you get TabSection.Settings pointing at that tab. Because this
-- runs after Misc, Settings shows up beside Misc under Other.
Win:ApplySettings(TabSection)

-- Line of text under the profile picture. Second argument true = scrub the name to Hidden
Library:UserSectionSet("Till: Never", true)

return Library
