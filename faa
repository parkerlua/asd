function Library:TryCloseColorpickerOutside(input)
    local Open = self.CurrentColorpicker
    if not Open or not Open.items or not Open.items.colorpicker_holder or not Open.trigger then
        return
    end
    task.defer(function()
        task.wait()
        Open = self.CurrentColorpicker
        if not Open or not Open.items or not Open.items.colorpicker_holder or not Open.trigger then
            return
        end
        local Focused = UserInputService:GetFocusedTextBox()
        if Focused and Open.items.input and Focused == Open.items.input then
            return
        end
        if not self._ColorpickerOpenLayer or Open.items.colorpicker_holder.Parent ~= self._ColorpickerOpenLayer then
            return
        end
        local Px, Py
        if input and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) then
            Px, Py = input.Position.X, input.Position.Y
        else
            local M = UserInputService:GetMouseLocation()
            Px, Py = M.X, M.Y
        end
        -- Second tap on the glyph closes the modal (trigger is under the open layer; use pointer hit-test).
        if self:PointInGuiObject(Px, Py, Open.trigger) then
            Open.open = false
            Open.set_visible(false)
            if self.CurrentColorpicker == Open then
                self.CurrentColorpicker = nil
            end
            return
        end
        if Open._suppress_colorpicker_outside_close then
            Open._suppress_colorpicker_outside_close = false
            return
        end
        if self:PointInGuiObject(Px, Py, Open.items.colorpicker_holder) then
            return
        end
        if Open.items.rainbow_row and self:PointInGuiObject(Px, Py, Open.items.rainbow_row) then
            return
        end
        if Open.items.bottom_stack and self:PointInGuiObject(Px, Py, Open.items.bottom_stack) then
            return
        end
        if Open.items.footer_copy and self:PointInGuiObject(Px, Py, Open.items.footer_copy) then
            return
        end
        if Open.items.footer_bar and self:PointInGuiObject(Px, Py, Open.items.footer_bar) then
            return
        end
        if Open.items.input and self:PointInGuiObject(Px, Py, Open.items.input) then
            return
        end
        if Open.items.hue_picker and self:PointInGuiObject(Px, Py, Open.items.hue_picker) then
            return
        end
        if Open.items.alpha_gradient and self:PointInGuiObject(Px, Py, Open.items.alpha_gradient) then
            return
        end
        if Open.items.alpha_indicator and self:PointInGuiObject(Px, Py, Open.items.alpha_indicator) then
            return
        end
        if Open.items.alpha_picker and self:PointInGuiObject(Px, Py, Open.items.alpha_picker) then
            return
        end
        if Open.items.satvalpicker and self:PointInGuiObject(Px, Py, Open.items.satvalpicker) then
            return
        end
        if Open.items.sat and self:PointInGuiObject(Px, Py, Open.items.sat) then
            return
        end
        if Open.items.hue_gradient and self:PointInGuiObject(Px, Py, Open.items.hue_gradient) then
            return
        end
        Open.open = false
        Open.set_visible(false)
        if self.CurrentColorpicker == Open then
            self.CurrentColorpicker = nil
        end
    end)
end

function Library:CloseDropdownIfAny()
    local Open = self.CurrentDropdown
    if Open and typeof(Open.close) == "function" then
        Open.close()
    end
end

function Library:TryCloseDropdownOutside(input)
    local Open = self.CurrentDropdown
    if not Open or not Open.list or not Open.trigger then
        return
    end
    -- Ignore stale deferred runs from a previous open (same pattern as Example.lua single-open, but session-scoped).
    local session = Open._dropdownOpenSession
    if typeof(session) ~= "number" then
        return
    end
    local px, py = self:_InputPointerXY(input)
    local lib = self
    task.defer(function()
        task.wait()
        Open = lib.CurrentDropdown
        if not Open or not Open.list or not Open.trigger then
            return
        end
        if Open._dropdownOpenSession ~= session then
            return
        end
        -- InputEnded + defer: avoids racing `Activated` / layout on the same click as `InputBegan`.
        if lib:PointInGuiObject(px, py, Open.list) or lib:PointInGuiObject(px, py, Open.trigger) then
            return
        end
        Open.close()
    end)
end

