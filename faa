            close = function() end,
        }

        local function ComputeDropdownListMinWidthPx()
            local optPadX = 2
            local checkCol = 18
            local gapAfterCheck = 8
            local textLeft = optPadX + checkCol + gapAfterCheck
            local bindReserve = anyOptionKeybind and 40 or 0
            local textRightPad = 4 + bindReserve
            local scrollPad = DROPDOWN_SCROLL_PAD_X * 2
            local reserve = scrollPad + textLeft + textRightPad + 8
            local tw = 72
            for _, OptStr in ipairs(OptionStrings) do
                local Str = tostring(OptStr)
                local TextWidth = LibraryRef:_MeasureTextWidthForFont(Str, 13, LibraryRef.Font)
                tw = MathMax(tw, MathFloor(TextWidth + reserve + 0.5))
            end
            return tw
        end

        local function PositionOpenList(ListFrame)
            if not ListFrame or not ListFrame.Parent or not Trigger.Parent then
                return
            end
            local ap = Trigger.AbsolutePosition
            local as = Trigger.AbsoluteSize
            local w = MathMax(as.X, DropdownState._listTargetWidth or 0)
            ListFrame.Size = NewUDim2(0, w, 0, ListFrame.Size.Y.Offset)
            local lh = ListFrame.Size.Y.Offset
            local vx = Camera.ViewportSize.X
            local vy = Camera.ViewportSize.Y
            local x = MathClamp(ap.X, 4, MathMax(4, vx - w - 4))
            local gap = DROPDOWN_POPUP_GAP_Y
            local belowY = ap.Y + as.Y + gap
            local aboveY = ap.Y - lh - gap
            local win = LibraryRef._WindowMainFrame
            if win and win.Parent then
                local wAp = win.AbsolutePosition
                local wSz = win.AbsoluteSize
                x = MathClamp(x, wAp.X + 4, MathMax(wAp.X + 4, wAp.X + wSz.X - w - 4))
                local pAp = ListFrame.Parent.AbsolutePosition
                local screenY = belowY + lh > vy - 4 and aboveY >= 4 and aboveY or belowY
                ListFrame.Position = NewUDim2(0, x - pAp.X, 0, screenY - pAp.Y)
                return
            end
            if belowY + lh > vy - 4 and aboveY >= 4 then
                ListFrame.Position = NewUDim2(0, x, 0, aboveY)
            else
                ListFrame.Position = NewUDim2(0, x, 0, belowY)
            end
        end

        local function CloseList()
            for _, Conn in ipairs(DropdownState.scrollConns) do
                Conn:Disconnect()
            end
            DropdownState.scrollConns = {}
            if DropdownState.chevronImg and DropdownState.chevronImg.Parent then
                DropdownState.chevronImg.Image = LibraryRef:TabIcon("chevron-down")
            end
            if DropdownState.list then
                DropdownState.list:Destroy()
                DropdownState.list = nil
            end
            DropdownState._listTargetWidth = nil
            if LibraryRef.CurrentDropdown == DropdownState then
                LibraryRef.CurrentDropdown = nil
            end
