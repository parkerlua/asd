            if On then
                CloseList()
            end
        end, DropDimList)

        local function RowSelected(idx)
            if Multi then
                return SelectedSet[idx] == true
            end
            return idx == CurrentIndex
        end

        local function RefreshOpenOptionRows()
            local lf = DropdownState.list
            if not lf or not lf.Parent then
                return
            end
            local sc = lf:FindFirstChild("dropdown_scroll", true)
            if not sc then
                return
            end
            for _, child in ipairs(sc:GetDescendants()) do
                if child:IsA("TextButton") and string.sub(child.Name, 1, 4) == "opt_" then
                    local oidx = tonumber(string.sub(child.Name, 5))
                    if oidx then
                        local sel = RowSelected(oidx)
                        child.BackgroundTransparency = 1
                        local tl = child:FindFirstChild("text")
                        if tl and tl:IsA("TextLabel") then
                            tl.TextColor3 = sel and Theme.Default or Theme.TextBody
                        end
                        local mk = child:FindFirstChild("check")
                        if mk and mk:IsA("ImageLabel") then
                            mk.ImageTransparency = sel and 0 or 1
                            mk.ImageColor3 = Theme.ActiveBg
                        end
                        local kpill = child:FindFirstChild("keybind_pill")
                        if kpill and kpill:IsA("GuiObject") then
                            kpill.BackgroundColor3 = Theme.Control
                            local kl = kpill:FindFirstChild("keybind_text")
                            if kl and kl:IsA("TextLabel") then
                                kl.TextColor3 = sel and Theme.Default or FromRgb(255, 255, 255)
                            end
                        end
                    end
                end
            end
        end

        local function CommitIdx(idx)
            CurrentIndex = MathClamp(idx, 1, #OptionStrings)
            LibraryRef.Flags[Flag] = CurrentIndex
            ValueLabel.Text = OptionStrings[CurrentIndex]
            Callback(OptionValues[CurrentIndex], CurrentIndex, OptionStrings[CurrentIndex])
            RefreshOpenOptionRows()
        end

        local function FormatMultiTriggerText()
            local texts = {}
            for i = 1, #OptionStrings do
                if SelectedSet[i] then
                    Insert(texts, OptionStrings[i])
                end
            end
            if #texts == 0 then
                return "None"
            end
            if #texts > 3 then
                return tostring(#texts) .. " selected"
            end
            return Concat(texts, ", ")
        end

        local function CommitMulti(fireCb)
            local indices = SelectedIndicesSorted()
            local values = {}
            local texts = {}
            for _, ix in ipairs(indices) do
                Insert(values, OptionValues[ix])
                Insert(texts, OptionStrings[ix])
            end
            LibraryRef.Flags[Flag] = indices
            ValueLabel.Text = FormatMultiTriggerText()
            if fireCb then
                Callback(values, indices, texts)
            end
            RefreshOpenOptionRows()
        end

        local function ApplyValueFromSet(v)
            if DropDis:IsDisabled() then
                return
            end
            if Multi then
                if typeof(v) == "table" then
                    local newSet = {}
                    for _, d in ipairs(v) do
                        if typeof(d) == "number" then
                            local ix = MathClamp(MathFloor(d + 0.5), 1, #OptionStrings)
                            newSet[ix] = true
                        elseif typeof(d) == "string" then
                            local hit = FindIdxByStringOrValue(d)
                            if hit then
                                newSet[hit] = true
                            end
                        end
                    end
                    SelectedSet = newSet
                    CommitMulti(true)
                elseif typeof(v) == "number" then
                    local ix = MathClamp(MathFloor(v + 0.5), 1, nOptions)
                    SelectedSet = { [ix] = true }
                    CommitMulti(true)
                end
            else
                if typeof(v) == "number" then
                    CommitIdx(MathFloor(v + 0.5))
                elseif typeof(v) == "string" then
                    local hit = FindIdxByStringOrValue(v)
                    if hit then
                        CommitIdx(hit)
                    end
                end
            end
        end

        LibraryRef:RegisterLangUpdater(function()
            RebuildOptionDisplayStrings()
            if NameLabel.Parent then
                NameLabel.Text = LibraryRef:ResolveLang(DropLabelLang, rawDropLabel)
            end
            if Multi then
                ValueLabel.Text = FormatMultiTriggerText()
            else
                ValueLabel.Text = OptionStrings[CurrentIndex] or ""
            end
            local lf = DropdownState.list
            if lf and lf.Parent then
                local sc = lf:FindFirstChild("dropdown_scroll", true)
                if sc then
                    for _, child in ipairs(sc:GetDescendants()) do
                        if child:IsA("TextButton") and string.sub(child.Name, 1, 4) == "opt_" then
                            local oidx = tonumber(string.sub(child.Name, 5))
                            if oidx then
                                local tl = child:FindFirstChild("text")
                                if tl and tl:IsA("TextLabel") then
                                    tl.Text = OptionStrings[oidx] or ""
                                end
                            end
                        end
                    end
                end
                RefreshOpenOptionRows()
            end
        end)

        if Multi then
            CommitMulti(true)
        else
            CommitIdx(CurrentIndex)
