    local RectOff = self:_ParseSectionImageVector2(Opt.ImageRectOffset or Opt.RectOffset or Opt.rectOffset)
    local RectSz = self:_ParseSectionImageVector2(Opt.ImageRectSize or Opt.RectSize or Opt.rectSize)
    local ElementVisible = Opt.Visible ~= false and Opt.visible ~= false
