local function NotifyParseIconColor(v)
    if typeof(v) == "Color3" then
        return v
    end
    if typeof(v) == "string" and v ~= "" then
        local h = v:gsub("^#", ""):gsub("%s+", "")
        if string.match(h, "^%x%x%x%x%x%x$") then
            return FromHex(h)
        end
    end
    return nil
end

local function ReflowNotifyActionButtonsHorizontal(ButtonsWrap)
    local buttons = {}
    for _, ch in ipairs(ButtonsWrap:GetChildren()) do
        if ch:IsA("TextButton") then
            Insert(buttons, ch)
        end
    end
    local n = #buttons
    if n == 0 then
        return
    end
    local g = NOTIFY_ACTION_GAP
    local function Apply()
        local w = ButtonsWrap.AbsoluteSize.X
        if w <= 1 then
            return false
        end
        if n == 1 then
            buttons[1].Size = NewUDim2(0, w, 0, NOTIFY_ACTION_H)
            return true
        end
        local totalGap = g * (n - 1)
        local avail = w - totalGap
        if avail < 0 then
            avail = 0
        end
        local base = MathFloor(avail / n)
        local rem = avail - base * n
        for i, btn in ipairs(buttons) do
            local extra = i <= rem and 1 or 0
            btn.Size = NewUDim2(0, base + extra, 0, NOTIFY_ACTION_H)
        end
        return true
    end
    if not Apply() then
        task.defer(function()
            if ButtonsWrap.Parent then
                Apply()
            end
        end)
    end
end

local function ParseNotifyAction(A, B)
    if type(A) == "table" then
        local o = A
        return tostring(o.Text or o.Name or o.name or o.text or "Button"), o.Callback or o.callback or function() end, o
    end
    return tostring(A or "Button"), type(B) == "function" and B or function() end, {}
end

local function WireNotifyButtonPress(Lib, Btn, IdleBg)
    local bgTween
    local function TweenBg(Color, UsePress)
        if bgTween then
            bgTween:Cancel()
        end
        bgTween = TweenService:Create(Btn, UsePress and NOTIFY_BTN_TI_PRESS or NOTIFY_BTN_TI_RELEASE,
            { BackgroundColor3 = Color })
        bgTween:Play()
    end
    Lib:Connection(Btn.MouseButton1Down, function()
        TweenBg(Theme.Inline, true)
    end)
    Lib:Connection(Btn.MouseButton1Up, function()
        TweenBg(IdleBg, false)
    end)
    Lib:Connection(Btn.MouseLeave, function()
        TweenBg(IdleBg, false)
    end)
end

