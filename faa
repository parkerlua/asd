    function SectionApi:AddMultiButton(Arg)
        local raw = {}
        if type(Arg) == "table" then
            if Arg.buttons or Arg.Buttons then
                raw = Arg.buttons or Arg.Buttons
            elseif Arg[1] ~= nil then
                raw = Arg
            end
        end

        local list = {}
        for _, Opt in ipairs(raw) do
            if type(Opt) == "table" then
                Insert(list, Opt)
            end
        end

        local n = #list
        if n == 0 then
            return { buttons = {} }
        end

        local Row = LibraryRef:CreateInstance("Frame", {
            Parent = scrolling,
            Name = "section_multibutton_row",
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Size = NewUDim2(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            ZIndex = 5,
        })

        local gap = 6
        local multiBtnH = 28
        LibraryRef:CreateInstance("UIListLayout", {
            Parent = Row,
            FillDirection = Enum.FillDirection.Horizontal,
            VerticalAlignment = Enum.VerticalAlignment.Center,
            HorizontalAlignment = Enum.HorizontalAlignment.Left,
            Padding = NewUDim(0, gap),
            SortOrder = Enum.SortOrder.LayoutOrder,
        })

        local out = {}
        local MultiDimList = {}
        local btnRefs = {}
        for i, Opt in ipairs(list) do
            local rawLabel = Opt.Name or Opt.name or Opt.Text or Opt.text or ("Button " .. tostring(i))
            local LabelLang = Opt.Lang or Opt.lang
            local LabelText = LibraryRef:ResolveLang(LabelLang, rawLabel)
            local Callback = Opt.Callback or Opt.callback or function() end
            local ConfirmNeeded = Opt.ConfirmNeeded == true or Opt.confirmNeeded == true
            local rawConfirm = Opt.ConfirmPrompt or Opt.confirmPrompt or "Are you sure?"
            local ConfirmLang = Opt.ConfirmLang or Opt.confirmLang

            local Btn = LibraryRef:CreateInstance("TextButton", {
                Parent = Row,
                Name = "section_multibutton_" .. i,
                AutoButtonColor = false,
                Text = LabelText,
                FontFace = Library.Font,
                TextSize = 13,
                TextColor3 = Theme.TextBody,
                BackgroundColor3 = Theme.PillSurface,
                BorderSizePixel = 0,
                -- Width set in ReflowSectionMultiButtonWidths (scale + gap math breaks for 3+ with UIListLayout).
                Size = NewUDim2(0, 1, 0, multiBtnH),
                LayoutOrder = i,
                ZIndex = 5,
            })
            Insert(btnRefs, Btn)

            LibraryRef:CreateInstance("UICorner", {
                Parent = Btn,
                CornerRadius = NewUDim(0, 6),
            })

            ApplySectionButtonPressColor(Btn, Theme.PillSurface)
            WireSectionTextButton(
                Btn,
                function()
                    return LibraryRef:ResolveLang(LabelLang, rawLabel)
                end,
                Callback,
                ConfirmNeeded,
                function()
                    return LibraryRef:ResolveLang(ConfirmLang, rawConfirm)
                end
            )

            LibraryRef:WireTooltip(Btn, Opt)

            Insert(MultiDimList, { Btn, "BackgroundColor3", 0.5 })
            Insert(MultiDimList, { Btn, "TextColor3", 0.42 })
            Insert(out, { button = Btn })
        end

        local function ReflowSectionMultiButtonWidths()
            local w = Row.AbsoluteSize.X
            if w <= 1 then
                return false
            end
            if n == 1 then
                btnRefs[1].Size = NewUDim2(0, w, 0, multiBtnH)
                return true
            end
            local totalGap = gap * (n - 1)
            local avail = w - totalGap
            if avail < 0 then
                avail = 0
            end
            local base = MathFloor(avail / n)
            local rem = avail - base * n
            for bi, btn in ipairs(btnRefs) do
                local extra = bi <= rem and 1 or 0
                btn.Size = NewUDim2(0, base + extra, 0, multiBtnH)
            end
            return true
        end

        if not ReflowSectionMultiButtonWidths() then
            task.defer(function()
                if Row.Parent then
                    ReflowSectionMultiButtonWidths()
                end
            end)
        end
        LibraryRef:Connection(Row:GetPropertyChangedSignal("AbsoluteSize"), ReflowSectionMultiButtonWidths)

        local RowDis = LibraryRef:AttachSetDisabledControl(Row, 100, nil, MultiDimList)
        local MultiBtnOut = {
            buttons = out,
        }
        function MultiBtnOut:SetDisabled(On)
            RowDis:SetDisabled(On)
        end

        function MultiBtnOut:IsDisabled()
            return RowDis:IsDisabled()
        end

        return MultiBtnOut
    end

