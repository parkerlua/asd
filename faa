function Library:_MountSectionViewport(Scrolling, Id, Opt)
    Opt = typeof(Opt) == "table" and Opt or {}

    local Height = tonumber(Opt.Height or Opt.height) or 200
    local UseClone = Opt.Clone ~= false and Opt.clone ~= false
    local Interactive = Opt.Interactive == true or Opt.interactive == true
    local AutoFocusOn = Opt.AutoFocus ~= false and Opt.autoFocus ~= false
    local UserCamera = Opt.Camera or Opt.camera
    local UserObject = Opt.Object or Opt.object
    local Callback = Opt.Callback or Opt.callback or function() end

    local SectionRow = self:CreateInstance("Frame", {
        Parent = Scrolling,
        Name = "section_viewport_row",
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = NewUDim2(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        ZIndex = 5,
    })

    local ViewportClip = self:CreateInstance("Frame", {
        Parent = SectionRow,
        Name = "viewport_clip",
        Active = false,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = NewUDim2(1, 0, 0, Height),
        ClipsDescendants = true,
        ZIndex = 5,
    })
    self:CreateInstance("UICorner", {
        Parent = ViewportClip,
        CornerRadius = NewUDim(0, 8),
    })

    local ViewportHost = self:CreateInstance("ViewportFrame", {
        Parent = ViewportClip,
        Name = "viewport_frame",
        Active = Interactive,
        BackgroundColor3 = Theme.Inline,
        BorderSizePixel = 0,
        Size = NewUDim2(1, 0, 1, 0),
        LightColor = FromRgb(255, 255, 255),
        Ambient = Theme.Inline:Lerp(FromRgb(255, 255, 255), 0.08),
        LightDirection = NewVector3(-1, -1, -1),
        ZIndex = 6,
    })
    self:CreateInstance("UICorner", {
        Parent = ViewportHost,
        CornerRadius = NewUDim(0, 8),
    })

    local ViewportCamera = UserCamera
    if typeof(ViewportCamera) ~= "Instance" or not ViewportCamera:IsA("Camera") then
        ViewportCamera = self:CreateInstance("Camera", { Parent = ViewportHost })
    else
        ViewportCamera.Parent = ViewportHost
    end
    ViewportHost.CurrentCamera = ViewportCamera

    local CurrentModel
    local BindFromCharacter = UserObject == nil
    local CharacterConnection
    local YawBase, PitchBase = MathRad(18), MathRad(-12)
    local OrbitYaw, OrbitPitch = YawBase, PitchBase
    local CameraDistance = 6
    local FocusCenter = NewVector3(0, 2, 0)

    local function StripScripts(Root)
        if not Root then
            return
        end
        for _, Desc in ipairs(Root:GetDescendants()) do
            if Desc:IsA("Script") or Desc:IsA("LocalScript") then
                Desc:Destroy()
            end
        end
    end

    local function GetFocusCenterAndDistance(ModelOrPart)
        if typeof(ModelOrPart) ~= "Instance" then
            return NewVector3(0, 2, 0), 3
        end
        if ModelOrPart:IsA("Model") then
            local BoundingCFrame, BoundingSize = ModelOrPart:GetBoundingBox()
            if BoundingCFrame and BoundingSize then
                local Half = MathMax(BoundingSize.X, BoundingSize.Y, BoundingSize.Z) * 0.5
                return BoundingCFrame.Position, MathMax(2.2, Half * 2.5)
            end
        elseif ModelOrPart:IsA("BasePart") then
            local Half = MathMax(ModelOrPart.Size.X, ModelOrPart.Size.Y, ModelOrPart.Size.Z) * 0.5
            return ModelOrPart.Position, MathMax(2.2, Half * 2.5)
        end
        return NewVector3(0, 2, 0), 4
    end

    local function ApplyViewportCamera()
        local Rot = CFrame.fromEulerAnglesYXZ(OrbitPitch, OrbitYaw, 0)
        local CamPos = (NewCFrame(FocusCenter) * Rot * NewCFrame(0, 0, CameraDistance)).Position
        ViewportCamera.CFrame = CFrame.lookAt(CamPos, FocusCenter)
    end

    local function ResetFocus()
        OrbitYaw, OrbitPitch = YawBase, PitchBase
        if CurrentModel and CurrentModel.Parent then
            FocusCenter, CameraDistance = GetFocusCenterAndDistance(CurrentModel)
        else
            FocusCenter = NewVector3(0, 2, 0)
            CameraDistance = 6
        end
        ApplyViewportCamera()
    end

    local function ClearDisplayedModel()
        if CurrentModel and CurrentModel.Parent then
            CurrentModel:Destroy()
        end
        CurrentModel = nil
    end

    local function PlaceModelAtOrigin(Instance)
        if Instance:IsA("Model") then
            Instance:PivotTo(NewCFrame())
        elseif Instance:IsA("BasePart") then
            Instance.Anchored = true
            Instance.CFrame = NewCFrame()
        end
    end

    local function DisplayFromInstance(Source)
        ClearDisplayedModel()
        if typeof(Source) ~= "Instance" then
            ApplyViewportCamera()
            return
        end
        local Instance
        if UseClone then
            local WasArchivable = Source.Archivable
            Source.Archivable = true
            local Cloned = Source:Clone()
            Source.Archivable = WasArchivable
            Instance = typeof(Cloned) == "Instance" and Cloned or nil
            if not Instance then
                ApplyViewportCamera()
                return
            end
            StripScripts(Instance)
        else
            Instance = Source
        end
        Instance.Parent = ViewportHost
        PlaceModelAtOrigin(Instance)
        CurrentModel = Instance
        if AutoFocusOn then
            task.defer(ResetFocus)
        else
            ApplyViewportCamera()
        end
    end

    local function AttachCharacterLifecycle()
        if not BindFromCharacter then
            return
        end
        if CharacterConnection then
            CharacterConnection:Disconnect()
            CharacterConnection = nil
        end
        CharacterConnection = LocalPlayer.CharacterAdded:Connect(function(Character)
            if Character then
                DisplayFromInstance(Character)
            end
        end)
        Insert(self.Connections, CharacterConnection)
        DisplayFromInstance(LocalPlayer.Character)
    end

    if UserObject ~= nil then
        DisplayFromInstance(UserObject)
    else
        AttachCharacterLifecycle()
    end

    local IsOrbitDragging, LastMousePixel = false, nil
    local PointerConnections = {}

    local ViewportDisableBinding = self:AttachSetDisabledControl(SectionRow, 100, nil, {
        { ViewportHost, "BackgroundColor3", 0.55 },
    })

    local SectionScroller = SectionRow.Parent
    local SectionScrollSaved = true
    local OrbitPanLockHeld = false
    local function BeginOrbitPan()
        if OrbitPanLockHeld then
            return
        end
        OrbitPanLockHeld = true
        self._ViewportOrbitPanDepth = (self._ViewportOrbitPanDepth or 0) + 1
        if SectionScroller and SectionScroller:IsA("ScrollingFrame") then
            SectionScrollSaved = SectionScroller.ScrollingEnabled
            SectionScroller.ScrollingEnabled = false
        end
    end
    local function EndOrbitPan()
        if not OrbitPanLockHeld then
            return
        end
        OrbitPanLockHeld = false
        self._ViewportOrbitPanDepth = math.max(0, (self._ViewportOrbitPanDepth or 1) - 1)
        if SectionScroller and SectionScroller:IsA("ScrollingFrame") then
            SectionScroller.ScrollingEnabled = SectionScrollSaved
        end
    end

    local function ConnectPointerHandlers()
        for _, Conn in ipairs(PointerConnections) do
            Conn:Disconnect()
        end
        PointerConnections = {}
        ViewportHost.Active = Interactive
        if not Interactive then
            IsOrbitDragging = false
            EndOrbitPan()
            return
        end
        local function MouseInViewportHost()
            return self:Hovering(ViewportHost)
        end
        local function IsControlDisabled()
            return ViewportDisableBinding:IsDisabled()
        end
        Insert(PointerConnections, self:Connection(UserInputService.InputBegan, function(Input, _)
            if IsControlDisabled() or not MouseInViewportHost() then
                return
            end
            if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                IsOrbitDragging = true
                LastMousePixel = UserInputService:GetMouseLocation()
                BeginOrbitPan()
            end
        end))
        Insert(PointerConnections, self:Connection(UserInputService.InputEnded, function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                IsOrbitDragging = false
                LastMousePixel = nil
                EndOrbitPan()
            end
        end))
        Insert(PointerConnections, self:Connection(UserInputService.InputChanged, function(Input, _)
            if IsControlDisabled() then
                return
            end
            if Input.UserInputType == Enum.UserInputType.MouseWheel and MouseInViewportHost() then
                CameraDistance = MathClamp(CameraDistance - Input.Position.Z * 0.65, 1.5, 48)
                ApplyViewportCamera()
            end
        end))
        Insert(PointerConnections, self:Connection(RunService.RenderStepped, function()
            if IsControlDisabled() or not IsOrbitDragging then
                return
            end
            if not UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                IsOrbitDragging = false
                LastMousePixel = nil
                EndOrbitPan()
                return
            end
            local MouseLoc = UserInputService:GetMouseLocation()
            if LastMousePixel then
                local Dx = MouseLoc.X - LastMousePixel.X
                local Dy = MouseLoc.Y - LastMousePixel.Y
                if Dx ~= 0 or Dy ~= 0 then
                    OrbitYaw = OrbitYaw - Dx * 0.01
                    OrbitPitch = MathClamp(OrbitPitch - Dy * 0.01, MathRad(-78), MathRad(78))
                    ApplyViewportCamera()
                end
            end
            LastMousePixel = MouseLoc
        end))
    end
    ConnectPointerHandlers()

    Insert(self.AccentUpdaters, function()
        if ViewportHost.Parent then
            ViewportHost.BackgroundColor3 = Theme.Inline
            ViewportHost.Ambient = Theme.Inline:Lerp(FromRgb(255, 255, 255), 0.08)
        end
        ViewportDisableBinding:SyncDimAfterTheme()
    end)

    local ViewportApi = { Frame = ViewportHost, Row = SectionRow }
    function ViewportApi:SetObject(Object)
        BindFromCharacter = false
        if CharacterConnection then
            CharacterConnection:Disconnect()
            CharacterConnection = nil
        end
        UserObject = Object
        if Object then
            DisplayFromInstance(Object)
        else
            ClearDisplayedModel()
            ApplyViewportCamera()
        end
    end

    function ViewportApi:SetCamera(Camera)
        if typeof(Camera) == "Instance" and Camera:IsA("Camera") then
            Camera.Parent = ViewportHost
            ViewportCamera = Camera
            ViewportHost.CurrentCamera = ViewportCamera
            ResetFocus()
        end
    end

    function ViewportApi:SetInteractive(On)
        Interactive = On == true
        ConnectPointerHandlers()
    end

    function ViewportApi:SetHeight(H)
        H = tonumber(H) or Height
        Height = MathClamp(H, 48, 720)
        ViewportClip.Size = NewUDim2(1, 0, 0, Height)
    end

    function ViewportApi:Focus()
        ResetFocus()
    end

    function ViewportApi:SetDisabled(On)
        ViewportDisableBinding:SetDisabled(On)
    end

    function ViewportApi:IsDisabled()
        return ViewportDisableBinding:IsDisabled()
    end

    self.Flags[Id] = ViewportApi
    Callback(ViewportApi)
    return ViewportApi
end

-- Section VideoFrame. ShowControls (default true): tap video to toggle; brief center flash (white play/pause + pulsing disc).
-- ShowScrubber (default true): time labels + seek bar under the clip (drag or click). Set ShowScrubber = false to hide.
-- Scrubber uses VideoFrame.TimeLength + TimePosition (Duration is not a valid member on VideoFrame).
function Library:_MountSectionVideo(Scrolling, Id, Opt)
    Opt = typeof(Opt) == "table" and Opt or {}

    local function FormatVideoTime(seconds)
        seconds = tonumber(seconds) or 0
        if seconds < 0 then
            seconds = 0
        end
        local h = MathFloor(seconds / 3600)
        local m = MathFloor((seconds % 3600) / 60)
        local s = MathFloor(seconds % 60)
        if h > 0 then
            return string.format("%d:%02d:%02d", h, m, s)
        end
        return string.format("%d:%02d", m, s)
    end

    local function NormalizeVideoAsset(V)
        if typeof(V) == "number" then
            return "rbxassetid://" .. tostring(MathFloor(V))
        end
        V = tostring(V or "")
        if V == "" then
            return ""
        end
        if string.match(V, "^rbxassetid://") or string.match(V, "^rbxasset://") or string.match(V, "^http") then
            return V
        end
        if string.match(V, "^%d+$") then
            return "rbxassetid://" .. V
        end
        return V
    end

    local Height = tonumber(Opt.Height or Opt.height) or 200
    local VideoAsset = NormalizeVideoAsset(Opt.Video or Opt.video or Opt.AssetId or Opt.assetId)
    local Looped = Opt.Looped == true or Opt.looped == true
    local Playing = Opt.Playing == true or Opt.playing == true
    local Volume = tonumber(Opt.Volume or Opt.volume)
    if Volume == nil then
        Volume = 1
    end
    Volume = MathClamp(Volume, 0, 1)
    local ElementVisible = Opt.Visible ~= false and Opt.visible ~= false
    local Callback = Opt.Callback or Opt.callback or function() end
    local ShowControls = Opt.ShowControls ~= false
        and Opt.showControls ~= false
        and Opt.Controls ~= false
        and Opt.controls ~= false
    local ShowScrubber = Opt.ShowScrubber ~= false
        and Opt.showScrubber ~= false
        and Opt.Scrubber ~= false
        and Opt.scrubber ~= false

    local SectionRow = self:CreateInstance("Frame", {
        Parent = Scrolling,
        Name = "section_video_row",
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = NewUDim2(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        Visible = ElementVisible,
        ZIndex = 5,
    })
    self:CreateInstance("UIListLayout", {
        Parent = SectionRow,
        FillDirection = Enum.FillDirection.Vertical,
        VerticalAlignment = Enum.VerticalAlignment.Top,
        HorizontalAlignment = Enum.HorizontalAlignment.Center,
        Padding = NewUDim(0, ShowScrubber and 4 or 0),
        SortOrder = Enum.SortOrder.LayoutOrder,
    })

    local VideoClip = self:CreateInstance("Frame", {
        Parent = SectionRow,
        Name = "video_clip",
        Active = false,
        BackgroundColor3 = Theme.Inline,
        BorderSizePixel = 0,
        Size = NewUDim2(1, 0, 0, Height),
        ClipsDescendants = true,
        ZIndex = 5,
        LayoutOrder = 1,
    })
    self:CreateInstance("UICorner", {
        Parent = VideoClip,
        CornerRadius = NewUDim(0, 8),
    })

    local VideoHost = self:CreateInstance("VideoFrame", {
        Parent = VideoClip,
        Name = "section_video",
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = NewUDim2(1, 0, 1, 0),
        Looped = Looped,
        Volume = Volume,
        ZIndex = 6,
    })
    if VideoAsset ~= "" then
        VideoHost.Video = VideoAsset
    end
    VideoHost.Playing = Playing

    self:CreateInstance("UICorner", {
        Parent = VideoHost,
        CornerRadius = NewUDim(0, 8),
    })

    local VideoDisableBinding = self:AttachSetDisabledControl(SectionRow, 100, nil, {
        { VideoHost, "BackgroundColor3", 0.55 },
    })

    local flashToken = 0
    if ShowControls then
        -- https://github.com/cascade-v/44/tree/main/rift — video-play-white.png / video-pause-white.png
        local PlayIconId = self:TabIcon("video-play-white")
        local PauseIconId = self:TabIcon("video-pause-white")

        local VideoTapLayer = self:CreateInstance("TextButton", {
            Parent = VideoClip,
            Name = "video_tap_layer",
            AutoButtonColor = false,
            Text = "",
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Size = NewUDim2(1, 0, 1, 0),
            Position = NewUDim2(0, 0, 0, 0),
            ZIndex = 7,
        })

        local FlashRoot = self:CreateInstance("Frame", {
            Parent = VideoClip,
            Name = "video_playback_flash",
            AnchorPoint = NewVector2(0.5, 0.5),
            Position = NewUDim2(0.5, 0, 0.5, 0),
            Size = NewUDim2(0, 82, 0, 82),
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Visible = false,
            Active = false,
            ClipsDescendants = false,
            ZIndex = 10,
        })

        local PulseDisc = self:CreateInstance("Frame", {
            Parent = FlashRoot,
            Name = "pulse_disc",
            AnchorPoint = NewVector2(0.5, 0.5),
            Position = NewUDim2(0.5, 0, 0.5, 0),
            Size = NewUDim2(0, 58, 0, 58),
            BackgroundColor3 = FromRgb(12, 12, 14),
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            ZIndex = 1,
        })
        self:CreateInstance("UICorner", {
            Parent = PulseDisc,
            CornerRadius = NewUDim(0, 29),
        })

        local GlyphTint = FromRgb(198, 200, 206)

        local PauseGlyph = self:CreateInstance("ImageLabel", {
            Parent = FlashRoot,
            Name = "icon_pause",
            AnchorPoint = NewVector2(0.5, 0.5),
            Position = NewUDim2(0.5, 0, 0.5, 0),
            Size = NewUDim2(0, 26, 0, 26),
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Image = PauseIconId,
            ImageColor3 = GlyphTint,
            ImageTransparency = 1,
            ScaleType = Enum.ScaleType.Fit,
            Visible = false,
            ZIndex = 2,
        })

        local PlayGlyph = self:CreateInstance("ImageLabel", {
            Parent = FlashRoot,
            Name = "icon_play",
            AnchorPoint = NewVector2(0.5, 0.5),
            Position = NewUDim2(0.5, 0, 0.5, 0),
            Size = NewUDim2(0, 26, 0, 26),
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Image = PlayIconId,
            ImageColor3 = GlyphTint,
            ImageTransparency = 1,
            ScaleType = Enum.ScaleType.Fit,
            Visible = false,
            ZIndex = 2,
        })

        local function ShowPlaybackFlash(nowPlaying)
            flashToken = flashToken + 1
            local tok = flashToken
            PauseGlyph.Visible = not nowPlaying
            PlayGlyph.Visible = nowPlaying
            PauseGlyph.ImageTransparency = 1
            PlayGlyph.ImageTransparency = 1
            PulseDisc.BackgroundTransparency = 1
            FlashRoot.Visible = true

            local TiIn = TweenInfo.new(0.14, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
            local TiHold = TweenInfo.new(0.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
            local TiOut = TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

            TweenService:Create(PulseDisc, TiIn, { BackgroundTransparency = 0.38 }):Play()
            if nowPlaying then
                TweenService:Create(PlayGlyph, TiIn, { ImageTransparency = 0.08 }):Play()
            else
                TweenService:Create(PauseGlyph, TiIn, { ImageTransparency = 0.08 }):Play()
            end

            task.delay(0.45, function()
                if tok ~= flashToken or not PulseDisc.Parent then
                    return
                end
                TweenService:Create(PulseDisc, TiHold, { BackgroundTransparency = 0.52 }):Play()
            end)

            task.delay(0.88, function()
                if tok ~= flashToken or not FlashRoot.Parent then
                    return
                end
                TweenService:Create(PulseDisc, TiOut, { BackgroundTransparency = 1 }):Play()
                TweenService:Create(PlayGlyph, TiOut, { ImageTransparency = 1 }):Play()
                TweenService:Create(PauseGlyph, TiOut, { ImageTransparency = 1 }):Play()
                task.delay(0.26, function()
                    if tok ~= flashToken or not FlashRoot.Parent then
                        return
                    end
                    FlashRoot.Visible = false
                end)
            end)
        end

        self:Connection(VideoTapLayer.MouseButton1Click, function()
            if VideoDisableBinding:IsDisabled() then
                return
            end
            local nowPlaying = not VideoHost.Playing
            VideoHost.Playing = nowPlaying
            ShowPlaybackFlash(nowPlaying)
        end)
    end

    local TrackBg, TrackFill, TrackThumb, TrackWrapRef, CurLbl, DurLbl, ScrubRow
    local scrubDragging = false
    local scrubEndConn
    local renderConn

    local function videoTrackRailColor()
        return Theme.Inline:Lerp(Theme.TextMuted, 0.5)
    end

    local function videoTrackThumbColor()
        return Theme.TextMuted:Lerp(Theme.TextBody, 0.42)
    end

    local function stopScrubDrag()
        scrubDragging = false
        if scrubEndConn then
            scrubEndConn:Disconnect()
            scrubEndConn = nil
        end
