-- Section controls: invisible hit-absorber + dim key visuals. DimSpecs entries:
-- { Instance, "Property", colorMix?, "transPlus"? } — Color3 lerp toward neutral, or add spec[3] to transparency when mode is "transPlus".
function Library:AttachSetDisabledControl(RowFrame, ZIndex, OnDisabledChange, DimSpecs)
    if typeof(RowFrame) ~= "Instance" or not RowFrame:IsA("GuiObject") then
        return {
            SetDisabled = function() end,
            IsDisabled = function()
                return false
            end,
            SyncDimAfterTheme = function() end,
        }
    end
    DimSpecs = DimSpecs or {}
    ZIndex = tonumber(ZIndex) or 90
    local Overlay = self:CreateInstance("Frame", {
        Name = "ControlDisabledOverlay",
        Parent = RowFrame,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = NewUDim2(1, 0, 1, 0),
        Visible = false,
        ZIndex = ZIndex,
        Active = true,
    })
    local snapshot = {}
    local Disabled = false

    local function applyDimFromCurrent()
        for i, spec in ipairs(DimSpecs) do
            local inst = spec[1]
            local prop = spec[2]
            if inst and inst.Parent and prop then
                local v = inst[prop]
                snapshot[i] = v
                local mixOrDelta = spec[3]
                local mode = spec[4]
                if mode == "transPlus" and typeof(v) == "number" then
                    inst[prop] = MathClamp(v + (mixOrDelta or 0.42), 0, 1)
                elseif typeof(v) == "Color3" then
                    inst[prop] = v:Lerp(FromRgb(38, 40, 46), mixOrDelta or 0.72)
                end
            end
        end
    end

    local function restoreDim()
        for i, spec in ipairs(DimSpecs) do
            local inst = spec[1]
            local prop = spec[2]
            if snapshot[i] ~= nil and inst and inst.Parent and prop then
                inst[prop] = snapshot[i]
            end
        end
        for k in pairs(snapshot) do
            snapshot[k] = nil
        end
    end

    return {
        SetDisabled = function(_, On)
            On = On == true
            if Disabled == On then
                return
            end
            Disabled = On
            if Overlay and Overlay.Parent then
                Overlay.Visible = On
            end
            if On then
                applyDimFromCurrent()
            else
                restoreDim()
            end
            if typeof(OnDisabledChange) == "function" then
                OnDisabledChange(On)
            end
        end,
        IsDisabled = function()
            return Disabled
        end,
        SyncDimAfterTheme = function()
            if Disabled then
                applyDimFromCurrent()
            end
        end,
    }
end

function Library:Hovering(UiObject)
    if typeof(UiObject) ~= "Instance" or not UiObject:IsA("GuiObject") then
        return false
    end
    local M = UserInputService:GetMouseLocation()
    local Ap = UiObject.AbsolutePosition
    local As = UiObject.AbsoluteSize
    return M.X >= Ap.X and M.X <= Ap.X + As.X and M.Y >= Ap.Y and M.Y <= Ap.Y + As.Y
end

-- Roblox `InputObject.Position` is a Vector3 (screen X/Y); older code often assumed Vector2.
function Library:_InputPointerXY(input)
    if input then
        local pos = input.Position
        if typeof(pos) == "Vector3" then
            return pos.X, pos.Y
        end
        if typeof(pos) == "Vector2" then
            return pos.X, pos.Y
        end
    end
    local M = UserInputService:GetMouseLocation()
    return M.X, M.Y
end

function Library:HoveringWithInput(UiObject, input)
    if typeof(UiObject) ~= "Instance" or not UiObject:IsA("GuiObject") then
        return false
    end
    local px, py = self:_InputPointerXY(input)
    return self:PointInGuiObject(px, py, UiObject)
end

function Library:PointInGuiObject(Px, Py, UiObject)
    if typeof(UiObject) ~= "Instance" or not UiObject:IsA("GuiObject") or not UiObject.Parent then
        return false
    end
    local Ap = UiObject.AbsolutePosition
    local As = UiObject.AbsoluteSize
    if As.X <= 0 or As.Y <= 0 then
        return false
    end
    return Px >= Ap.X and Px <= Ap.X + As.X and Py >= Ap.Y and Py <= Ap.Y + As.Y
end

-- `TextService:GetTextSize` with `FontFace` can throw "Unable to cast Font to Font" on some clients with custom fonts.
-- Measuring via `TextBounds` matches rendered labels (same approach as keybind pill width).
function Library:_MeasureTextWidthForFont(text, textSize, fontFace)
    text = tostring(text or "")
    textSize = tonumber(textSize) or 13
    fontFace = fontFace or self.Font
    if text == "" then
        return 0
    end
    local gui = self._WindowScreenGui
    if not gui or not gui.Parent then
        return #text * 8
    end
    local ml = self._TextWidthMeasureLabel
    if not ml or not ml.Parent then
        ml = self:CreateInstance("TextLabel", {
            Name = "_TextWidthMeasure",
            Parent = gui,
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Size = NewUDim2(0, 10000, 0, textSize + 8),
            Position = NewUDim2(0, -10000, 0, -10000),
            Visible = false,
            Text = "",
            TextWrapped = false,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextYAlignment = Enum.TextYAlignment.Top,
            TextTruncate = Enum.TextTruncate.None,
        })
        self._TextWidthMeasureLabel = ml
    end
    ml.FontFace = fontFace
    ml.TextSize = textSize
    ml.Text = text
    local w = ml.TextBounds.X
    if typeof(w) ~= "number" or w <= 0 then
        return #text * 8
    end
    return w
end

function Library:Tween(Inst, Props, EasingStyle, Duration)
    local Ti = TweenInfo.new(
        Duration or 0.2,
        EasingStyle or Enum.EasingStyle.Quad,
        Enum.EasingDirection.Out
    )
