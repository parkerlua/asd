                return Current
            end,
            rail = Rail,
        }
        function SliderOut:SetDisabled(On)
            SliderDis:SetDisabled(On)
        end

        function SliderOut:IsDisabled()
            return SliderDis:IsDisabled()
        end

        return SliderOut
    end

