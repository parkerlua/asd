        local Current = DefaultV

        local function Snap(V)
            if Rounding >= 1 then
                return MathClamp(
                    MathFloor(V / Rounding + 0.5) * Rounding,
                    MinV,
                    MaxV
                )
            end
            local m = 1 / Rounding
            return MathClamp(MathFloor(V * m + 0.5) / m, MinV, MaxV)
        end

        local function Proportion(V)
            if MaxV == MinV then
                return 0
            end
            return (V - MinV) / (MaxV - MinV)
        end

        local function FormatValue(V)
            if Rounding >= 1 then
                return tostring(MathFloor(V + 0.5))
            end
            local s = string.format("%.2f", V)
            return s
        end

        local function ApplyVisual()
            local p = Proportion(Current)
            local glowLeft = p > 0.001 and 4 or 0
            Fill.Position = NewUDim2(0, 0, 0.5, 0)
            Fill.Size = NewUDim2(p, 0, 0, 4)
            FillGlowImg.Position = NewUDim2(0, -glowLeft, 0.5, 0)
            FillGlowImg.Size = NewUDim2(p, glowLeft, 0, 13)
            FillGlowImg.Visible = p > 0.001
            Thumb.Position = NewUDim2(p, (1 - 2 * p) * ThumbHalfPx, 0.5, 0)
            ValueLabel.Text = FormatValue(Current)
        end

        local function Commit(V)
            Current = Snap(V)
            LibraryRef.Flags[Flag] = Current
            ApplyVisual()
            Callback(Current)
        end

