-- Library:IslandNotify("Message", duration) | Library:IslandNotify({ Text = "...", Duration = 4, Icon = "person", IconColor = ... })
-- Or Library:Notify({ ..., Island = true, Description = "..." })
function Library:IslandNotify(A, B)
    self.IslandQue = self.IslandQue or {}
    local Lib = self
    local MessageText
    local Life = 4
    local Persist = false
    local Opt = nil
    local IconSpec = "person"
    if type(A) == "table" then
        Opt = A
        MessageText = A.Text or A.text or A.Message or A.message or A.Description or A.description or A.Body or A.body or
        A.Title or A.title or ""
        Life = tonumber(A.Duration or A.duration or A.Time or A.time) or 4
        Persist = A.Persist == true or A.persist == true
        if A.Icon ~= nil or A.icon ~= nil then
            IconSpec = A.Icon or A.icon
        end
    elseif type(A) == "string" and type(B) == "number" then
        MessageText = A
        Life = tonumber(B) or 4
    else
        MessageText = tostring(A or "")
        Life = tonumber(B) or 4
    end
    MessageText = tostring(MessageText or "")
    if Life <= 0 then
        Life = 0.05
    end

    local Host = self:EnsureIslandHost()
    if not Host or not Host.Parent then
        return nil
    end

    local hostW = Host.AbsoluteSize.X
    if hostW < 80 then
        hostW = 480
    end
    local capOuter = math.min(ISLAND_MAX_W, math.max(100, hostW - 48))
    local iconAndGap = 18 + 6
    local textMaxW = MathMax(40, capOuter - ISLAND_PAD_X * 2 - iconAndGap)

    local Card = self:CreateInstance("CanvasGroup", {
        Parent = Host,
        Name = "island_card",
        BackgroundColor3 = Theme.Background,
        BackgroundTransparency = 0,
        BorderSizePixel = 0,
        GroupTransparency = 1,
        Position = NewUDim2(0, 0, 0, ISLAND_SAFE_TOP - ISLAND_SLIDE_IN),
        Size = NewUDim2(0, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.XY,
        ZIndex = 506,
    })
    self:CreateInstance("UICorner", {
        Parent = Card,
        CornerRadius = NewUDim(0, ISLAND_CORNER),
    })
    self:CreateInstance("UIPadding", {
        Parent = Card,
        PaddingLeft = NewUDim(0, ISLAND_PAD_X),
        PaddingRight = NewUDim(0, ISLAND_PAD_X),
        PaddingTop = NewUDim(0, ISLAND_PAD_Y),
        PaddingBottom = NewUDim(0, ISLAND_PAD_Y),
    })

    self:CreateInstance("UIListLayout", {
        Parent = Card,
        FillDirection = Enum.FillDirection.Horizontal,
        VerticalAlignment = Enum.VerticalAlignment.Center,
        HorizontalAlignment = Enum.HorizontalAlignment.Left,
        Padding = NewUDim(0, 6),
        SortOrder = Enum.SortOrder.LayoutOrder,
    })

    local IconWrap = self:CreateInstance("Frame", {
        Parent = Card,
        Name = "island_icon_wrap",
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = NewUDim2(0, 18, 0, 18),
        LayoutOrder = 1,
    })
    local IslandIcon = self:CreateInstance("ImageLabel", {
        Parent = IconWrap,
        Name = "island_icon",
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        AnchorPoint = NewVector2(0.5, 0.5),
        Position = NewUDim2(0.5, 0, 0.5, 0),
        Size = NewUDim2(0, 15, 0, 15),
        Image = self:TabIcon(IconSpec),
        ImageColor3 = Theme.ActiveBg,
        ScaleType = Enum.ScaleType.Fit,
        ZIndex = 2,
    })
    if Opt then
        local icn = NotifyParseIconColor(Opt.IconColor or Opt.iconColor)
        if icn then
            IslandIcon.ImageColor3 = icn
        end
    end

    local MsgLabel = self:CreateInstance("TextLabel", {
        Parent = Card,
        Name = "island_message",
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = NewUDim2(0, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.XY,
        FontFace = Library.Font,
        Text = MessageText,
        TextColor3 = FromRgb(255, 255, 255),
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
        TextTruncate = Enum.TextTruncate.AtEnd,
        TextWrapped = false,
        LayoutOrder = 2,
        ZIndex = 2,
    })
    self:CreateInstance("UISizeConstraint", {
        Parent = MsgLabel,
        MaxSize = NewVector2(textMaxW, 40),
    })

    if Opt then
        local sid = Opt.SoundId or Opt.soundId
        if sid ~= nil then
            local snd = Instance.new("Sound")
            snd.Parent = SoundService
            if typeof(sid) == "number" then
                snd.SoundId = "rbxassetid://" .. tostring(sid)
            else
                local s = tostring(sid)
                if string.match(s, "^%d+$") then
                    snd.SoundId = "rbxassetid://" .. s
                else
                    snd.SoundId = s
                end
            end
            snd.Volume = 0.45
            snd:Play()
            Debris:AddItem(snd, 8)
        end
    end

    local Entry = { Frame = Card }
    Insert(self.IslandQue, Entry)
    self:RefreshIslandLayout(false)

    local TargetPos = Card.Position
    Card.Position = NewUDim2(TargetPos.X.Scale, TargetPos.X.Offset, TargetPos.Y.Scale,
        TargetPos.Y.Offset - ISLAND_SLIDE_IN)
    self:Tween(Card, { Position = TargetPos }, Enum.EasingStyle.Quad, ISLAND_FADE_IN)
    self:Tween(Card, { GroupTransparency = 0 }, Enum.EasingStyle.Quad, ISLAND_FADE_IN)

    task.defer(function()
        if Card.Parent then
            Lib:RefreshIslandLayout(false)
        end
    end)

    local Closed = false
    local function CloseNow()
        if Closed then
            return
        end
        Closed = true
        for i, Item in ipairs(self.IslandQue) do
            if Item == Entry then
                Remove(self.IslandQue, i)
                break
            end
        end
        local P = Card.Position
        self:Tween(Card, { Position = NewUDim2(P.X.Scale, P.X.Offset, P.Y.Scale, P.Y.Offset - ISLAND_SLIDE_IN) },
            Enum.EasingStyle.Quad, ISLAND_FADE_OUT)
        TweenService:Create(
            Card,
            TweenInfo.new(ISLAND_FADE_OUT, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
            { GroupTransparency = 1 }
        ):Play()
        task.delay(ISLAND_FADE_OUT + 0.06, function()
            if Card and Card.Parent then
                Card:Destroy()
            end
            Lib:RefreshIslandLayout(true)
        end)
    end

    function Entry:ChangeMessage(t)
        MsgLabel.Text = tostring(t or "")
        Lib:RefreshIslandLayout(false)
    end

    function Entry:Destroy()
        CloseNow()
    end

    if not Persist then
        task.delay(Life, CloseNow)
    end

    return Entry
end

