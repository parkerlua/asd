    local function UniqueTabIdFromTitle(Title)
        local S = string.lower(tostring(Title))
        S = string.gsub(S, "%s+", "_")
        S = string.gsub(S, "[^%a%d_]", "")
        if S == "" then
            S = "tab"
        end
        local Base = S
        local Id = Base
        local N = 2
        while TabRows[Id] do
            Id = Base .. "_" .. N
            N += 1
        end
        return Id
    end

