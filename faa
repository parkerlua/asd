function Library:GetLangIndex()
    local n = #self.Langs
    if n <= 0 then
        return 1
    end
    local i = self._LangIndex
    if typeof(i) ~= "number" then
        return 1
    end
    i = MathFloor(i + 0.5)
    if i < 1 or i > n then
        return 1
    end
    return i
end

function Library:SetLangIndex(idx, skipRefresh)
    local n = #self.Langs
    if n <= 0 then
        self._LangIndex = 1
        return
    end
    idx = MathClamp(MathFloor((idx or 1) + 0.5), 1, n)
    self._LangIndex = idx
    if not skipRefresh then
        self:RefreshLang()
    end
end

function Library:ResolveLang(langSpec, fallback)
    local fb = fallback ~= nil and tostring(fallback) or ""
    if langSpec == nil then
        return fb
    end
    if typeof(langSpec) ~= "table" then
        return tostring(langSpec)
    end
    local i = self:GetLangIndex()
    local v = langSpec[i]
    if v ~= nil and tostring(v) ~= "" then
        return tostring(v)
    end
    v = langSpec[1]
    if v ~= nil and tostring(v) ~= "" then
        return tostring(v)
    end
    return fb
end

function Library:RegisterLangUpdater(Updater)
    if typeof(Updater) ~= "function" then
        return
    end
    Insert(self.LangUpdaters, Updater)
end

-- Applies `Library.Flags.cfg_ui_language` to `_LangIndex`, then runs all lang updaters.
-- Call after loading a config (or any time the flag changes) so UI strings stay in sync.
function Library:RefreshLang()
    local nLang = #self.Langs
    if nLang > 0 then
        local ix = self.Flags["cfg_ui_language"]
        if typeof(ix) == "number" then
            self:SetLangIndex(MathClamp(MathFloor(ix + 0.5), 1, nLang), true)
        end
    end
    self:RefreshFontFromFlag()
    for _, LangUpdater in ipairs(self.LangUpdaters) do
        LangUpdater()
    end
end

