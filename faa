    local function applyScrubScreenX(px)
        if VideoDisableBinding:IsDisabled() or not TrackWrapRef or not TrackWrapRef.Parent then
            return
        end
        local dur = VideoHost.TimeLength
        if dur <= 0 then
            return
        end
        local ax = TrackWrapRef.AbsolutePosition.X
        local aw = TrackWrapRef.AbsoluteSize.X
        if aw <= 1 then
            return
        end
        local alpha = MathClamp((px - ax) / aw, 0, 1)
        VideoHost.TimePosition = alpha * dur
    end

    if ShowScrubber then
        ScrubRow = self:CreateInstance("Frame", {
            Parent = SectionRow,
