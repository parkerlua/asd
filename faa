        ScaleType = ScaleType,
        ZIndex = 6,
    })
    self:CreateInstance("UICorner", {
        Parent = Img,
        CornerRadius = NewUDim(0, 8),
    })

    local ImageDisableBinding = self:AttachSetDisabledControl(SectionRow, 100, nil, {
        { Img, "ImageColor3", 0.72 },
    })

    Insert(self.AccentUpdaters, function()
        if ImageClip.Parent then
            ImageClip.BackgroundColor3 = Theme.Inline
        end
        ImageDisableBinding:SyncDimAfterTheme()
    end)

    local ImageApi = { image = Img, Row = SectionRow }
    function ImageApi:SetHeight(H)
        H = tonumber(H) or Height
        Height = MathClamp(H, 32, 720)
        ImageClip.Size = NewUDim2(1, 0, 0, Height)
    end

    function ImageApi:SetImage(Spec)
        Resolved = self:ResolveColorpickerImage(Spec)
        Img.Image = Resolved
    end

    function ImageApi:SetColor(C)
        if typeof(C) == "Color3" then
            Tint = C
            Img.ImageColor3 = Tint
        end
    end

    function ImageApi:SetScaleType(ST)
        ScaleType = self:_ParseSectionImageScaleType(ST)
        Img.ScaleType = ScaleType
    end

    function ImageApi:SetTransparency(T)
        T = tonumber(T)
        if T == nil then
            return
        end
        ImgTransparency = MathClamp(T, 0, 1)
