function Library:MakeDraggable(TargetFrame, DragHandle)
    local Handle = DragHandle or TargetFrame
    local IsDragging = false
    local DragStart = nil
    local StartPosition = nil

    Handle.InputBegan:Connect(function(Input)
        if Input.UserInputType ~= Enum.UserInputType.MouseButton1
            and Input.UserInputType ~= Enum.UserInputType.Touch then
            return
        end
        IsDragging = true
        DragStart = Input.Position
        StartPosition = TargetFrame.Position
    end)

    Handle.InputEnded:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1
            or Input.UserInputType == Enum.UserInputType.Touch then
            IsDragging = false
        end
    end)

    self:Connection(UserInputService.InputChanged, function(Input)
        if not IsDragging then
            return
        end
        if Input.UserInputType ~= Enum.UserInputType.MouseMovement
            and Input.UserInputType ~= Enum.UserInputType.Touch then
            return
        end
        if (self._ViewportOrbitPanDepth or 0) > 0 then
            return
        end
        if not DragStart or not StartPosition then
            return
        end

        local Delta = Input.Position - DragStart
        local ViewportX = Camera.ViewportSize.X
        local ViewportY = Camera.ViewportSize.Y
        local NewX = MathClamp(
            StartPosition.X.Offset + Delta.X,
            0,
            ViewportX - TargetFrame.AbsoluteSize.X
        )
        local NewY = MathClamp(
            StartPosition.Y.Offset + Delta.Y,
            0,
            ViewportY - TargetFrame.AbsoluteSize.Y
        )
        TargetFrame.Position = NewUDim2(0, NewX, 0, NewY)
    end)
end

function Library:MakeResizable(TargetFrame, Options)
    Options = Options or {}
    local GripPx = typeof(Options.GripPx) == "number" and Options.GripPx or 12
    local MinW = typeof(Options.MinWidth) == "number" and Options.MinWidth or 450
    local MinH = typeof(Options.MinHeight) == "number" and Options.MinHeight or 450
    local MaxW = Options.MaxWidth
    local MaxH = Options.MaxHeight

    local Resizing = false
    local StartMouse = nil
    local StartSize = nil

    local Grip = self:CreateInstance("TextButton", {
        Name = "ResizeGrip",
        Parent = TargetFrame,
        AnchorPoint = NewVector2(1, 1),
        Position = NewUDim2(1, 0, 1, 0),
        Size = NewUDim2(0, GripPx, 0, GripPx),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Text = "",
        AutoButtonColor = false,
        ZIndex = 40,
        Active = true,
    })

    self:CreateInstance("ImageLabel", {
        Name = "ResizeGripIcon",
        Parent = Grip,
        AnchorPoint = NewVector2(0.5, 0.5),
        Position = NewUDim2(0.5, 0, 0.5, 0),
        Size = NewUDim2(1, -2, 1, -2),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Image = (self.IconsBaseUrl or "") .. (self.AssetManifest["resize-grip"] or "prohibit-icon-white.png"),
        ImageColor3 = FromRgb(255, 255, 255),
        ScaleType = Enum.ScaleType.Fit,
        ZIndex = 41,
        Active = false,
    })

    local function ClampSize(Width, Height)
        local vp = Camera.ViewportSize
        local pos = TargetFrame.AbsolutePosition
        local roomW = vp.X - pos.X - 2
        local roomH = vp.Y - pos.Y - 2
        roomW = MathMax(MinW, roomW)
        roomH = MathMax(MinH, roomH)
        if typeof(MaxW) == "number" then
            roomW = MathMin(roomW, MaxW)
        end
        if typeof(MaxH) == "number" then
            roomH = MathMin(roomH, MaxH)
        end
        return MathClamp(Width, MinW, roomW), MathClamp(Height, MinH, roomH)
    end

    Grip.InputBegan:Connect(function(Input)
        if
            Input.UserInputType ~= Enum.UserInputType.MouseButton1
            and Input.UserInputType ~= Enum.UserInputType.Touch
        then
            return
        end
        Resizing = true
        StartMouse = NewVector2(Input.Position.X, Input.Position.Y)
        StartSize = NewVector2(TargetFrame.AbsoluteSize.X, TargetFrame.AbsoluteSize.Y)
    end)

    self:Connection(UserInputService.InputEnded, function(Input)
        if
            Input.UserInputType == Enum.UserInputType.MouseButton1
            or Input.UserInputType == Enum.UserInputType.Touch
        then
            Resizing = false
        end
    end)

    self:Connection(UserInputService.InputChanged, function(Input)
        if not Resizing or not StartMouse or not StartSize then
            return
        end
        if (self._ViewportOrbitPanDepth or 0) > 0 then
            return
        end
        if
            Input.UserInputType ~= Enum.UserInputType.MouseMovement
            and Input.UserInputType ~= Enum.UserInputType.Touch
        then
            return
        end
        local cur = NewVector2(Input.Position.X, Input.Position.Y)
        local delta = cur - StartMouse
        local w, h = ClampSize(StartSize.X + delta.X, StartSize.Y + delta.Y)
        TargetFrame.Size = NewUDim2(0, w, 0, h)
    end)
end

function Library:GetOrCreateTooltipLayer(ScreenGui)
    if not ScreenGui then
        return nil
    end
    local layers = self.TooltipLayers
    if not layers then
        layers = {}
        self.TooltipLayers = layers
    end
    local entry = layers[ScreenGui]
    if entry then
        return entry
    end

    local Bubble = self:CreateInstance("Frame", {
        Name = "Tooltip",
        Parent = ScreenGui,
        BackgroundColor3 = Theme.TooltipBg,
        BorderSizePixel = 0,
        Visible = false,
        AutomaticSize = Enum.AutomaticSize.XY,
        ZIndex = 30000,
        Active = false,
    })
    self:CreateInstance("UICorner", {
        Parent = Bubble,
        CornerRadius = NewUDim(0, 6),
    })
    self:CreateInstance("UIStroke", {
        Parent = Bubble,
        Color = Theme.Divider,
        Thickness = 1,
    })
    self:CreateInstance("UIPadding", {
        Parent = Bubble,
        PaddingLeft = NewUDim(0, 10),
        PaddingRight = NewUDim(0, 10),
        PaddingTop = NewUDim(0, 7),
        PaddingBottom = NewUDim(0, 7),
    })
    local Lbl = self:CreateInstance("TextLabel", {
        Parent = Bubble,
        Name = "TooltipText",
        BackgroundTransparency = 1,
        Text = "",
        TextColor3 = Theme.TextBody,
        TextSize = 12,
        FontFace = Library.Font,
        TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top,
        Size = NewUDim2(0, 240, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        Active = false,
    })

    entry = {
        Bubble = Bubble,
        Label = Lbl,
        MoveConn = nil,
        TargetElement = nil,
    }
    layers[ScreenGui] = entry
    return entry
end

function Library:_TooltipPlaceBubble(Bubble)
    local Ml = UserInputService:GetMouseLocation()
    local vw, vh = Camera.ViewportSize.X, Camera.ViewportSize.Y
    local w = Bubble.AbsoluteSize.X
    local h = Bubble.AbsoluteSize.Y
    if w < 2 or h < 2 then
        w = 200
        h = 44
    end
    local x = Ml.X + 14
    local y = Ml.Y + 10
    x = MathClamp(x, 8, vw - w - 8)
    y = MathClamp(y, 8, vh - h - 8)
    Bubble.AnchorPoint = NewVector2(0, 0)
    Bubble.Position = NewUDim2(0, x, 0, y)
end

function Library:_ShowTooltipForElement(Element, Text)
    local sg = Element:FindFirstAncestorWhichIsA("ScreenGui")
    if not sg then
        return
    end
    local layer = self:GetOrCreateTooltipLayer(sg)
    if not layer then
        return
    end

    if layer.MoveConn then
        layer.MoveConn:Disconnect()
        layer.MoveConn = nil
    end

    layer.TargetElement = Element
    layer.Label.Text = Text
    layer.Bubble.Visible = true
    self:_TooltipPlaceBubble(layer.Bubble)
    task.defer(function()
        if layer.TargetElement ~= Element or not layer.Bubble.Visible then
            return
        end
        self:_TooltipPlaceBubble(layer.Bubble)
    end)

    layer.MoveConn = UserInputService.InputChanged:Connect(function(Input)
        if Input.UserInputType ~= Enum.UserInputType.MouseMovement then
            return
        end
        if layer.TargetElement ~= Element or not layer.Bubble.Visible then
            return
        end
        self:_TooltipPlaceBubble(layer.Bubble)
    end)
end

function Library:_HideTooltipIfFromElement(Element)
    local sg = Element:FindFirstAncestorWhichIsA("ScreenGui")
    if not sg then
        return
    end
    local layers = self.TooltipLayers
    if not layers then
        return
    end
    local layer = layers[sg]
    if not layer or layer.TargetElement ~= Element then
        return
    end
    if layer.MoveConn then
        layer.MoveConn:Disconnect()
        layer.MoveConn = nil
    end
    layer.TargetElement = nil
    layer.Bubble.Visible = false
end

function Library:_ParseTooltipParts(Opt)
    if type(Opt) ~= "table" then
        return nil, nil, nil
    end
    local tip = Opt.Tooltip or Opt.tooltip
    local tipLang = Opt.TooltipLang or Opt.tooltipLang
    if tip == nil and tipLang == nil then
        return nil, nil, nil
    end
    local base = tip ~= nil and tostring(tip) or ""
    local d = Opt.TooltipDelay or Opt.tooltipDelay
    if type(d) ~= "number" or d < 0 then
        d = nil
    end
    return base, tipLang, d
end

-- One-shot resolved tooltip (uses current language). Prefer `WireTooltip` so tooltips track language changes.
function Library:ParseTooltipOptions(Opt)
    local base, tipLang, d = self:_ParseTooltipParts(Opt)
    if base == nil and tipLang == nil then
        return nil, nil
    end
    local resolved = self:ResolveLang(tipLang, base)
    if resolved == "" then
        return nil, nil
    end
    return resolved, d
end

function Library:BindTooltip(Element, TooltipText, DelaySec)
    if typeof(Element) ~= "Instance" then
        return
    end
    TooltipText = TooltipText and tostring(TooltipText) or ""
    if TooltipText == "" then
        return
    end
    if type(DelaySec) ~= "number" or DelaySec < 0 then
        DelaySec = 0.42
    end

    local hoverToken = 0
    self:Connection(Element.MouseEnter, function()
        hoverToken = hoverToken + 1
        local myTok = hoverToken
        task.delay(DelaySec, function()
            if myTok ~= hoverToken then
                return
            end
            if not Element.Parent then
                return
            end
            self:_ShowTooltipForElement(Element, TooltipText)
        end)
    end)
    self:Connection(Element.MouseLeave, function()
        hoverToken = hoverToken + 1
        self:_HideTooltipIfFromElement(Element)
    end)
end

function Library:WireTooltip(Element, Opt)
    if typeof(Element) ~= "Instance" then
        return
    end
    local base, tipLang, delay = self:_ParseTooltipParts(Opt)
    if base == nil and tipLang == nil then
        return
    end
    if type(delay) ~= "number" or delay < 0 then
        delay = 0.42
    end
    local hoverToken = 0
    self:Connection(Element.MouseEnter, function()
        hoverToken = hoverToken + 1
        local myTok = hoverToken
        task.delay(delay, function()
            if myTok ~= hoverToken then
                return
            end
            if not Element.Parent then
                return
            end
            local text = self:ResolveLang(tipLang, base)
            if text == "" then
                return
            end
            self:_ShowTooltipForElement(Element, text)
        end)
    end)
    self:Connection(Element.MouseLeave, function()
        hoverToken = hoverToken + 1
        self:_HideTooltipIfFromElement(Element)
    end)
end

function Library:FormatKeybindDisplay(Value)
    if Value == nil then
        return "None"
    end
    if type(Value) == "table" then
        local kc = Value.KeyCode
        local ms = Value.Mouse
        if kc then
            return KeyNames[kc] or kc.Name
        end
        if ms then
            return KeyNames[ms] or ms.Name
        end
    end
    return "None"
end

function Library:KeybindInputMatchesStored(Input, KeyVal)
    local K = self:NormalizeKeybindValue(KeyVal)
    if not K then
        return false
    end
    if K.KeyCode then
        return Input.KeyCode == K.KeyCode
    end
    if K.Mouse then
        return Input.UserInputType == K.Mouse
    end
    return false
end

function Library:NormalizeKeybindValue(V)
    if V == nil then
        return nil
    end
    if typeof(V) == "EnumItem" and V.EnumType == Enum.KeyCode then
        return { KeyCode = V }
    end
    if typeof(V) == "EnumItem" and V.EnumType == Enum.UserInputType then
        return { Mouse = V }
    end
    if type(V) == "table" then
        if V.KeyCode then
            return { KeyCode = V.KeyCode }
        end
        if V.Mouse then
            return { Mouse = V.Mouse }
        end
    end
    return nil
end

