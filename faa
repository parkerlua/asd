    local function NormalizeMultiTabTitles(...)
        local n = select("#", ...)
        if n == 0 then
            return {}
        end
        if n == 1 then
            local A = select(1, ...)
            if type(A) == "table" then
                local Out = {}
                for _, X in ipairs(A) do
                    Insert(Out, tostring(X))
                end
                return Out
            end
            return { tostring(A) }
        end
        local Out = {}
        for i = 1, n do
            Insert(Out, tostring(select(i, ...)))
        end
        return Out
    end

