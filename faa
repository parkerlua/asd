        local DragUsesHeartbeat = false

        local function ValueFromAbsoluteX(AbsX)
            local x0 = Rail.AbsolutePosition.X
            local w = Rail.AbsoluteSize.X
            if w < 1 then
                return Current
            end
            local inner = w - 2 * ThumbHalfPx
            if inner < 1 then
                inner = 1
            end
            local t = (AbsX - x0 - ThumbHalfPx) / inner
            t = MathClamp(t, 0, 1)
            return Snap(MinV + (MaxV - MinV) * t)
        end

