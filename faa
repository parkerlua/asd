function Library:_FontApplyRoots()
    local roots = {}
    local seen = {}
    local function add(r)
        if typeof(r) == "Instance" and r.Parent and not seen[r] then
            seen[r] = true
            Insert(roots, r)
        end
    end
    add(self._CurrentWindow and self._CurrentWindow.Gui)
    add(self.KeybindList and self.KeybindList.Gui)
    add(self._WatermarkGui)
    add(self._MobileChromeGui)
    add(self._NotifyScreenGui)
    add(self._WindowScreenGui)
    return roots
end

function Library:_ApplyFontFaceToRoot(root, face)
    if not root or not face then
        return
    end
    for _, d in root:GetDescendants() do
        if d:IsA("TextLabel") or d:IsA("TextButton") or d:IsA("TextBox") then
            d.FontFace = face
        end
    end
end

function Library:ApplyUIFont(face)
    if not face then
        return
    end
    self.Font = face
    for _, root in self:_FontApplyRoots() do
        self:_ApplyFontFaceToRoot(root, face)
    end
    local layers = self.TooltipLayers
    if type(layers) == "table" then
        for _, layer in pairs(layers) do
            if type(layer) == "table" and layer.Label and layer.Label.Parent then
                layer.Label.FontFace = face
            end
        end
    end
end

function Library:SetFontIndex(idx, skipFlag)
    local faces = self._FontFaces
    if not faces or #faces == 0 then
        return
    end
    idx = MathClamp(MathFloor((idx or 1) + 0.5), 1, #faces)
    local face = faces[idx]
    self:ApplyUIFont(face)
    if not skipFlag then
        self.Flags["cfg_ui_font"] = idx
    end
end

function Library:GetFontIndex()
    local faces = self._FontFaces
    if not faces or #faces == 0 then
        return 1
    end
    local ix = self.Flags["cfg_ui_font"]
    if typeof(ix) == "number" then
        return MathClamp(MathFloor(ix + 0.5), 1, #faces)
    end
    return 1
end

function Library:RefreshFontFromFlag()
    local faces = self._FontFaces
    if not faces or #faces == 0 then
        return
    end
    local ix = self.Flags["cfg_ui_font"]
    if typeof(ix) ~= "number" then
        return
    end
    ix = MathClamp(MathFloor(ix + 0.5), 1, #faces)
    self:SetFontIndex(ix, true)
end

