    function SectionApi:AddDropdown(options)
        local Opt = typeof(options) == "table" and options or {}
        local rawDropLabel = typeof(options) == "string" and options
            or (Opt.Name or Opt.name or Opt.Text or Opt.text or "Dropdown")
        local DropLabelLang = Opt.Lang or Opt.lang
        local LabelText = LibraryRef:ResolveLang(DropLabelLang, rawDropLabel)
        local Flag = Opt.flag or Opt.Flag or LibraryRef:NextFlag()
        local Callback = Opt.Callback or Opt.callback or function() end

        local RawList = Opt.Options or Opt.options or  Opt.Values or Opt.values or {}
        local OptionDisplayBase = {}
        local OptionLangSpecs = {}
        local OptionValues = {}
        local OptionKeybinds = {}
        for i, v in ipairs(RawList) do
            if typeof(v) == "table" then
                local sv = v.Text or v.text or v.Label or v.label or v.Value or v.value
                local disp = typeof(sv) == "string" and sv or tostring(sv ~= nil and sv or i)
                Insert(OptionDisplayBase, disp)
                Insert(OptionLangSpecs, v.Lang or v.lang)
                local rawVal = v.Value or v.value
                Insert(OptionValues, rawVal ~= nil and rawVal or disp)
                local kbRaw = v.Keybind or v.keybind or v.Bind or v.bind or v.Key or v.key
                local kbStr = nil
                if typeof(kbRaw) == "string" and kbRaw ~= "" then
                    kbStr = kbRaw
                elseif typeof(kbRaw) == "EnumItem" and kbRaw.EnumType == Enum.KeyCode then
                    kbStr = kbRaw.Name
                end
                Insert(OptionKeybinds, kbStr)
            else
                Insert(OptionDisplayBase, tostring(v))
                Insert(OptionLangSpecs, nil)
                Insert(OptionValues, v)
                Insert(OptionKeybinds, nil)
            end
        end
        if #OptionDisplayBase == 0 then
            Insert(OptionDisplayBase, "—")
            Insert(OptionLangSpecs, nil)
            Insert(OptionValues, "—")
            Insert(OptionKeybinds, nil)
        end

        local OptionStrings = {}
        local function RebuildOptionDisplayStrings()
            for i = 1, #OptionDisplayBase do
                OptionStrings[i] = LibraryRef:ResolveLang(OptionLangSpecs[i], OptionDisplayBase[i])
            end
