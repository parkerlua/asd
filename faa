function Library:_RefreshUserSectionAll()
    self._UserSectionSlots = self._UserSectionSlots or {}
    local desc = self._UserSectionDescription
    if desc == nil then
        desc = ""
    end
    desc = tostring(desc)
    local nameStr = self._UserSectionAnon == true and "Hidden" or self:_UserSectionDisplayName()
    for _, slot in ipairs(self._UserSectionSlots) do
        local u, s = slot.User, slot.Sub
        if u and u.Parent then
            u.Text = nameStr
        end
        if s and s.Parent then
            s.Text = desc
        end
    end
end

