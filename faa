function Library:LoadIconManifest()
    local Base = self.IconsBaseUrl
    if type(Base) ~= "string" or Base == "" then
        return
    end
    if Base:sub(-1) ~= "/" then
        Base = Base .. "/"
    end
    local Fn = getcustomasset or get_custom_asset
    if type(Fn) ~= "function" then
        return
    end
    local AssetDir = self.Directory .. "/Assets"
    for Key, FileName in pairs(self.AssetManifest) do
        local FullPath = AssetDir .. "/" .. FileName
        if not self:FileExists(FullPath) and type(writefile) == "function" then
            local Body = game:HttpGet(Base .. FileName)
            if type(Body) == "string" and #Body > 0 then
                writefile(FullPath, Body)
            end
        end
        if self:FileExists(FullPath) then
            local AssetId = Fn(FullPath)
            if type(AssetId) == "string" and AssetId ~= "" then
                self.Assets[Key] = AssetId
            end
        end
    end
end

