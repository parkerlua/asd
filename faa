    local TabFadeGeneration = 0
    local TAB_FADE_OUT = 0.14
    local TAB_FADE_IN = 0.16

    local function SetActiveNavTab(Id)
        if Id == ActiveTabId then
            return
        end
        if not TabRows[Id] or not TabRows[Id].Panel then
            return
        end
        TabFadeGeneration = TabFadeGeneration + 1
        local Gen = TabFadeGeneration

        local PreviousId = ActiveTabId
        local OldPanel = PreviousId and TabRows[PreviousId] and TabRows[PreviousId].Panel
        local NewPanel = TabRows[Id].Panel

        ActiveTabId = Id
        for TabKey, Row in pairs(TabRows) do
            local P = Row.Panel
            if P then
                if TabKey ~= Id and P ~= OldPanel then
                    P.Visible = false
                    P.GroupTransparency = 0
                end
                P.Position = NewUDim2(0, 0, 0, 0)
            end
            StyleNavTab(Row)
        end

        local function ApplySearchIfCurrent()
            if Gen == TabFadeGeneration then
                ApplyActiveTabSearch()
            end
        end

        local function ShowNewPanel()
            if Gen ~= TabFadeGeneration then
                return
            end
            NewPanel.Visible = true
            NewPanel.GroupTransparency = 1
            local tiIn = TweenInfo.new(TAB_FADE_IN, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
            local twIn = TweenService:Create(NewPanel, tiIn, { GroupTransparency = 0 })
            twIn.Completed:Connect(function()
                if Gen == TabFadeGeneration then
                    ApplySearchIfCurrent()
                end
            end)
            twIn:Play()
        end

        if OldPanel and OldPanel ~= NewPanel and OldPanel.Visible then
            local tiOut = TweenInfo.new(TAB_FADE_OUT, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
            local twOut = TweenService:Create(OldPanel, tiOut, { GroupTransparency = 1 })
            twOut.Completed:Connect(function()
                if Gen ~= TabFadeGeneration then
                    return
                end
                OldPanel.Visible = false
                OldPanel.GroupTransparency = 0
                ShowNewPanel()
            end)
            twOut:Play()
        else
            if OldPanel and OldPanel ~= NewPanel then
                OldPanel.Visible = false
                OldPanel.GroupTransparency = 0
            end
            ShowNewPanel()
        end
    end

