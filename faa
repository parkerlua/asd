local function RegisterFontAsset(FontName, SourceUrl, Weight, Style)
    local FontsFolder = Library.Directory .. "/Fonts"
    local TtfPath = FontsFolder .. "/" .. FontName .. ".ttf"
    local FontDescriptorPath = FontsFolder .. "/" .. FontName .. ".font"
    local getca = getcustomasset or get_custom_asset
    if type(isfile) ~= "function" or type(writefile) ~= "function" or type(getca) ~= "function" then
        return nil
    end
    if not isfile(TtfPath) then
        if type(SourceUrl) ~= "string" or SourceUrl == "" or type(game.HttpGet) ~= "function" then
            return nil
        end
        local body = game:HttpGet(SourceUrl)
        if type(body) ~= "string" or #body == 0 then
            return nil
        end
        writefile(TtfPath, body)
    end
    if not isfile(TtfPath) then
        return nil
    end
    if isfile(FontDescriptorPath) then
        delfile(FontDescriptorPath)
    end
    local Descriptor = {
        name = FontName,
        faces = {
            {
                name = "Regular",
                weight = Weight or 400,
                style = Style or "Normal",
                assetId = getca(TtfPath),
            },
        },
    }
    writefile(FontDescriptorPath, HttpService:JSONEncode(Descriptor))
    return getca(FontDescriptorPath)
end

local function BuildFontFaceFromCatalogEntry(entry)
    local asset = RegisterFontAsset(
        entry.FileKey,
        entry.Url,
        entry.FaceWeight or 400,
        entry.FaceStyle or "Normal"
    )
    if type(asset) ~= "string" or asset == "" then
        return nil
    end
    local fw = entry.FontWeight or Enum.FontWeight.SemiBold
    local fs = entry.FontStyle or Enum.FontStyle.Normal
    return Font.new(asset, fw, fs)
end

